<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] — HMS</title>
  <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  @await RenderSectionAsync("Styles", required: false)
  <!-- Sidebar pre-init: prevents expand/collapse flash on page load -->
  <script>
  (function(){
    var s=document.createElement('style');s.id='sb-pre';
    var col=localStorage.getItem('sidebarCollapsed')==='true'&&window.innerWidth>768;
    if(col){s.textContent='#sidebar{width:60px!important;min-width:60px!important;overflow:hidden!important;transition:none!important}#sidebar .sidebar-label,#sidebar .sl-text,#sidebar .badge-count{display:none!important}#sidebar .sidebar-link{justify-content:center!important;padding:.6rem 0!important}#sidebar .sidebar-link i{margin:0!important}';}
    else{s.textContent='#sidebar{transition:none!important}';}
    document.head.appendChild(s);
    window.addEventListener('DOMContentLoaded',function(){setTimeout(function(){var e=document.getElementById('sb-pre');if(e)e.remove();},60);});
  })();
  </script>
</head>
<body>

@{
  string roleBadge = "";
  string roleColor = "#6b7280";
  if (User.IsInRole("Website_Admin"))          { roleBadge = "Admin";        roleColor = "#0f4c81"; }
  else if (User.IsInRole("Website_Doctor"))    { roleBadge = "Doctor";       roleColor = "#059669"; }
  else if (User.IsInRole("Website_Patient"))   { roleBadge = "Patient";      roleColor = "#0e7490"; }
  else if (User.IsInRole("Website_Nurse"))     { roleBadge = "Nurse";        roleColor = "#7c3aed"; }
  else if (User.IsInRole("Website_LabTech"))   { roleBadge = "Lab Tech";     roleColor = "#d97706"; }
  else if (User.IsInRole("Website_Pharmacist")){ roleBadge = "Pharmacist";   roleColor = "#e11d48"; }
  else if (User.IsInRole("Website_Receptionist")){ roleBadge = "Receptionist"; roleColor = "#ea580c"; }
  else if (User.IsInRole("Website_Accountant")){ roleBadge = "Accountant";   roleColor = "#16a34a"; }
  // FullName claim is injected by ApplicationUserClaimsPrincipalFactory (shows real name not email)
  string displayName = User.FindFirst("FullName")?.Value
                    ?? User.Identity?.Name
                    ?? "User";
  var nameParts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
  string initials = nameParts.Length >= 2
      ? $"{nameParts[0][0]}{nameParts[^1][0]}".ToUpper()
      : (displayName.Length >= 2 ? displayName[..2].ToUpper() : displayName.ToUpper());
}

<!-- ── TOP NAV ─────────────────────────────────────────────────────────── -->
<nav class="topbar">
  <button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()" aria-label="Toggle sidebar">
    <i class="fas fa-bars"></i>
  </button>
  <a class="topbar-brand" asp-controller="Home" asp-action="Index" asp-area="">
    <i class="fas fa-hospital-alt"></i> <span>MedCore HMS</span>
  </a>
  <div class="topbar-spacer"></div>
  <div class="topbar-nav">
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
      @if (!string.IsNullOrEmpty(roleBadge))
      {
        <span class="role-badge" style="background:@roleColor;">@roleBadge</span>
      }
      <div class="user-dropdown" id="userDropdown">
        <button class="user-btn" onclick="toggleDropdown()">
          <span class="avatar">@initials</span>
          <span class="user-name">@displayName</span>
          <i class="fas fa-chevron-down" style="font-size:.65rem; opacity:.7;"></i>
        </button>
        <div class="dropdown-menu-custom" id="dropdownMenu">
          <div class="dropdown-user-info">
            <div class="dropdown-avatar">@initials</div>
            <div>
              <div style="font-weight:600;font-size:.875rem;">@displayName</div>
              @if (!string.IsNullOrEmpty(roleBadge))
              {
                <div style="font-size:.75rem;color:@roleColor;font-weight:500;">@roleBadge</div>
              }
            </div>
          </div>
          <div class="divider"></div>
          @if (User.IsInRole("Website_Admin"))
          {
            <a asp-area="Admin" asp-controller="Home" asp-action="Index">
              <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
          }
          @if (User.IsInRole("Website_Doctor"))
          {
            <a asp-area="Doctor" asp-controller="Home" asp-action="Index">
              <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
          }
          @if (User.IsInRole("Website_Patient"))
          {
            <a asp-area="Patient" asp-controller="Home" asp-action="Index">
              <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
          }
          @if (User.IsInRole("Website_Nurse"))
          {
            <a asp-area="Nurse" asp-controller="Home" asp-action="Index">
              <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
          }
          @if (User.IsInRole("Website_LabTech"))
          {
            <a asp-area="LabTech" asp-controller="Home" asp-action="Index">
              <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
          }
          @if (User.IsInRole("Website_Pharmacist"))
          {
            <a asp-area="Pharmacist" asp-controller="Home" asp-action="Index">
              <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
          }
          @if (User.IsInRole("Website_Receptionist"))
          {
            <a asp-area="Receptionist" asp-controller="Home" asp-action="Index">
              <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
          }
          @if (User.IsInRole("Website_Accountant"))
          {
            <a asp-area="Accountant" asp-controller="Home" asp-action="Index">
              <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
          }
          <div class="divider"></div>
          <a asp-controller="Profile" asp-action="Index" asp-area="">
            <i class="fas fa-user-circle"></i> My Profile
          </a>
          <a asp-controller="Profile" asp-action="ChangePassword" asp-area="">
            <i class="fas fa-key"></i> Change Password
          </a>
          <div class="divider"></div>
          <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post" id="logoutForm">
            @Html.AntiForgeryToken()
            <button type="submit" class="danger"><i class="fas fa-sign-out-alt"></i> Sign Out</button>
          </form>
        </div>
      </div>
    }
    else
    {
      <a class="nav-link" asp-controller="Auth" asp-action="Login" asp-area="">
        <i class="fas fa-sign-in-alt"></i><span> Login</span>
      </a>
      <a class="nav-link" asp-controller="Auth" asp-action="Register" asp-area="">
        <i class="fas fa-user-plus"></i><span> Register</span>
      </a>
    }
  </div>
</nav>

<!-- ── BODY ────────────────────────────────────────────────────────────── -->
