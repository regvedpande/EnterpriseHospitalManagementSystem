@model Hospital.Web.Controllers.LoginVm
@{
    ViewData["Title"] = "Sign In";
    ViewData["ShowSidebar"] = false;
    Layout = "_Layout";
}

<div class="auth-page">
  <div style="display:flex; gap:2rem; align-items:flex-start; max-width:860px; width:100%;">

    <!-- Login Card -->
    <div class="auth-card" style="flex:1; min-width:320px;">
      <div class="auth-card-header">
        <div class="logo"><i class="fas fa-hospital-alt"></i> MedCore HMS</div>
        <p>Sign in to your workspace</p>
      </div>
      <div class="auth-card-body">
        <form asp-action="Login" method="post">
          <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]"/>
          <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "flex")"></div>

          <div class="form-group">
            <label class="form-label" asp-for="Email"><i class="fas fa-envelope" style="margin-right:.4rem;opacity:.6;"></i> Email Address</label>
            <input asp-for="Email" class="form-control" placeholder="you@hospital.com" autocomplete="email"/>
            <span asp-validation-for="Email" class="invalid-feedback"></span>
          </div>
          <div class="form-group">
            <label class="form-label" asp-for="Password"><i class="fas fa-lock" style="margin-right:.4rem;opacity:.6;"></i> Password</label>
            <div style="position:relative;">
              <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" id="passwordInput"/>
              <button type="button" onclick="togglePassword()" style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted);padding:0;">
                <i class="fas fa-eye" id="eyeIcon"></i>
              </button>
            </div>
            <span asp-validation-for="Password" class="invalid-feedback"></span>
          </div>
          <div class="form-group" style="display:flex; align-items:center; gap:.5rem;">
            <input asp-for="RememberMe" type="checkbox" id="RememberMe" style="width:16px;height:16px;cursor:pointer;accent-color:var(--primary);"/>
            <label for="RememberMe" style="margin:0; font-size:.875rem; cursor:pointer;">Keep me signed in for 8 hours</label>
          </div>
          <button type="submit" class="btn btn-primary w-100 btn-lg" style="margin-top:.75rem;">
            <i class="fas fa-sign-in-alt"></i> Sign In
          </button>
        </form>
      </div>
      <div class="auth-card-footer">
        New patient? <a asp-action="Register">Create an account</a>
      </div>
    </div>

    <!-- Demo Credentials Panel -->
    <div style="flex:1; min-width:280px; display:flex; flex-direction:column; gap:.75rem;">
      <div style="background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.15); border-radius:12px; padding:1.25rem; color:#fff;">
        <div style="font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; opacity:.6; margin-bottom:.875rem;">
          <i class="fas fa-key" style="margin-right:.4rem;"></i> Demo Credentials
        </div>
        @foreach (var c in new[] {
          new { Role = "Admin",       Email = "admin@hospital.com",       Pass = "Admin@123",        Color = "#60a5fa" },
          new { Role = "Doctor",      Email = "doctor@hospital.com",      Pass = "Doctor@123",       Color = "#34d399" },
          new { Role = "Nurse",       Email = "nurse@hospital.com",       Pass = "Nurse@123",        Color = "#c084fc" },
          new { Role = "Patient",     Email = "patient@hospital.com",     Pass = "Patient@123",      Color = "#67e8f9" },
          new { Role = "Lab Tech",    Email = "labtech@hospital.com",     Pass = "LabTech@123",      Color = "#fbbf24" },
          new { Role = "Pharmacist",  Email = "pharmacist@hospital.com",  Pass = "Pharmacist@123",   Color = "#f87171" },
          new { Role = "Reception",   Email = "receptionist@hospital.com",Pass = "Receptionist@123", Color = "#fb923c" },
          new { Role = "Accountant",  Email = "accountant@hospital.com",  Pass = "Accountant@123",   Color = "#4ade80" },
        })
        {
          <div class="demo-cred" onclick="fillCredentials('@c.Email','@c.Pass')" title="Click to auto-fill">
            <span class="demo-role-dot" style="background:@c.Color;"></span>
            <div style="flex:1; min-width:0;">
              <div style="font-weight:600; font-size:.8rem; color:@c.Color;">@c.Role</div>
              <div style="font-size:.75rem; opacity:.65; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@c.Email</div>
            </div>
            <i class="fas fa-mouse-pointer" style="font-size:.7rem; opacity:.4;"></i>
          </div>
        }
        <div style="margin-top:.75rem; padding:.5rem .75rem; background:rgba(255,255,255,.06); border-radius:8px; font-size:.72rem; opacity:.65;">
          <i class="fas fa-info-circle" style="margin-right:.3rem;"></i> Click any role to auto-fill credentials
        </div>
      </div>
    </div>

  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial"/>
  <script>
    function fillCredentials(email, password) {
      document.getElementById('Email').value = email;
      document.getElementById('Password').value = password;
    }
    function togglePassword() {
      const inp = document.getElementById('passwordInput');
      const ico = document.getElementById('eyeIcon');
      if (inp.type === 'password') {
        inp.type = 'text';
        ico.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        inp.type = 'password';
        ico.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }
  </script>
}

@section Styles {
<style>
.demo-cred {
  display: flex; align-items: center; gap: .75rem;
  padding: .5rem .75rem; border-radius: 8px; cursor: pointer;
  transition: background .15s; margin-bottom: .25rem;
}
.demo-cred:hover { background: rgba(255,255,255,.08); }
.demo-role-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
@@media (max-width: 640px) {
  .auth-page > div { flex-direction: column !important; }
}
</style>
}
