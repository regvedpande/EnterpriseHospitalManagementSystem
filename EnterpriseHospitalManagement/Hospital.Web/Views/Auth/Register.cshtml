@model Hospital.Web.Controllers.RegisterVm
@using Hospital.Models.Enums
@{
    ViewData["Title"] = "Register";
    ViewData["ShowSidebar"] = false;
    Layout = "_Layout";
}

<div class="auth-page">
  <div class="auth-card" style="max-width:520px;">
    <div class="auth-card-header">
      <div class="logo"><i class="fas fa-hospital-alt"></i> HMS</div>
      <p>Create your patient account</p>
    </div>
    <div class="auth-card-body">
      <form asp-action="Register" method="post">
        <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "flex")"></div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" asp-for="Name">Full Name</label>
            <input asp-for="Name" class="form-control" placeholder="John Smith"/>
            <span asp-validation-for="Name" class="invalid-feedback"></span>
          </div>
          <div class="form-group">
            <label class="form-label" asp-for="Email">Email</label>
            <input asp-for="Email" class="form-control" placeholder="you@email.com"/>
            <span asp-validation-for="Email" class="invalid-feedback"></span>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" asp-for="Password">Password</label>
            <input asp-for="Password" class="form-control" placeholder="Min 6 characters"/>
            <span asp-validation-for="Password" class="invalid-feedback"></span>
          </div>
          <div class="form-group">
            <label class="form-label" asp-for="ConfirmPassword">Confirm Password</label>
            <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat password"/>
            <span asp-validation-for="ConfirmPassword" class="invalid-feedback"></span>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" asp-for="Gender">Gender</label>
            <select asp-for="Gender" class="form-control" asp-items="Html.GetEnumSelectList<Gender>()"></select>
          </div>
          <div class="form-group">
            <label class="form-label" asp-for="DOB">Date of Birth</label>
            <input asp-for="DOB" type="date" class="form-control"/>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" asp-for="Address">Address <span style="color:var(--text-muted)">(optional)</span></label>
          <input asp-for="Address" class="form-control" placeholder="Your address"/>
        </div>
        <button type="submit" class="btn btn-success w-100 btn-lg" style="margin-top:.5rem;">
          <i class="fas fa-user-plus"></i> Create Account
        </button>
      </form>
    </div>
    <div class="auth-card-footer">
      Already have an account? <a asp-action="Login">Sign in</a>
    </div>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial"/>
}
