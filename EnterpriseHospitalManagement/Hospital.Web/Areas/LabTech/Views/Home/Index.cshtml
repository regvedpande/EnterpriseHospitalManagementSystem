@{ ViewData["Title"] = "Lab Tech Dashboard"; ViewData["ShowSidebar"] = true; }
<div class="page-header"><div><div class="page-title">Welcome, @User.Identity?.Name</div><small class="text-muted">Lab Technician Dashboard</small></div></div>
<div class="stats-grid">
  <div class="stat-card"><div class="stat-icon" style="background:#e3f2fd;"><i class="fas fa-flask" style="color:#1976d2;"></i></div><div class="stat-info"><div class="stat-number">@ViewBag.TotalTests</div><div class="stat-label">Total Tests</div></div></div>
  <div class="stat-card"><div class="stat-icon" style="background:#e8f5e9;"><i class="fas fa-vials" style="color:#388e3c;"></i></div><div class="stat-info"><div class="stat-number">@ViewBag.MyTests</div><div class="stat-label">My Tests</div></div></div>
</div>
