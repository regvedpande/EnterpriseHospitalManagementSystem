@{
    ViewData["Title"]       = "Lab AI Assistant";
    ViewData["ShowSidebar"] = true;
    bool cfg = (bool)(ViewBag.IsConfigured ?? false);
}
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-robot" style="color:#d97706;"></i> Lab AI Assistant</div>
    <small class="text-muted">Result interpretation · Test panel suggestions · Clinical significance</small>
  </div>
</div>
@if (!cfg) { <div class="alert alert-warning"><i class="fas fa-exclamation-triangle"></i> AI service not configured.</div> }
else {
<ul class="nav nav-pills mb-3 gap-2 flex-wrap" id="aiTabs">
  <li class="nav-item"><button class="nav-link active" data-tab="result"><i class="fas fa-microscope"></i> Interpret Result</button></li>
  <li class="nav-item"><button class="nav-link" data-tab="panel"><i class="fas fa-vials"></i> Suggest Test Panel</button></li>
  <li class="nav-item"><button class="nav-link" data-tab="chat"><i class="fas fa-comments"></i> Lab Chat</button></li>
</ul>

<div class="ai-tab" id="tab-result">
  <div class="card"><div class="card-header ai-hdr" style="background:linear-gradient(135deg,#d97706,#fbbf24);">
    <i class="fas fa-microscope"></i> Lab Result Interpretation
  </div><div class="card-body d-flex flex-column gap-3">
    <div class="row g-2">
      <div class="col-md-5"><label class="form-label small">Test Name</label><input id="r-test" class="form-control" placeholder="e.g. Haemoglobin, Creatinine, TSH"/></div>
      <div class="col-md-3"><label class="form-label small">Result Value</label><input id="r-val" class="form-control" placeholder="e.g. 6.8"/></div>
      <div class="col-md-2"><label class="form-label small">Unit</label><input id="r-unit" class="form-control" placeholder="e.g. g/dL"/></div>
    </div>
    <textarea id="r-ctx" class="form-control" rows="2" placeholder="Patient context e.g. 45yo female, symptomatic fatigue, vegetarian diet, no current medications"></textarea>
    <button class="btn btn-warning" id="r-btn" onclick="runInterpret()">
      <i class="fas fa-search"></i> Interpret Result
    </button>
    <div id="r-res" class="ai-result" style="display:none;border-color:#d97706;background:#fffbeb;"></div>
  </div></div>
</div>

<div class="ai-tab" id="tab-panel" style="display:none;">
  <div class="card"><div class="card-header ai-hdr" style="background:linear-gradient(135deg,#4facfe,#00f2fe);">
    <i class="fas fa-vials"></i> Test Panel Suggestion
  </div><div class="card-body d-flex flex-column gap-3">
    <textarea id="p-cond" class="form-control" rows="4" placeholder="Describe the clinical presentation or suspected condition…&#10;e.g. Young patient with fatigue, weight gain, cold intolerance, constipation, and dry skin — suspected thyroid disorder"></textarea>
    <button class="btn btn-info" id="p-btn" onclick="runPanel()">
      <i class="fas fa-list"></i> Suggest Test Panel
    </button>
    <div id="p-res" class="ai-result" style="display:none;border-color:#4facfe;background:#eff6ff;"></div>
  </div></div>
</div>

<div class="ai-tab" id="tab-chat" style="display:none;">
  <div class="card" style="height:520px;display:flex;flex-direction:column;">
    <div class="card-header ai-hdr" style="background:linear-gradient(135deg,#d97706,#4facfe);">
      <i class="fas fa-comments"></i> Lab Q&amp;A Chat
    </div>
    <div id="chatBox" class="flex-grow-1 p-3" style="overflow-y:auto;background:#f8f9fa;"></div>
    <div class="card-footer p-2"><div class="input-group">
      <input id="chatIn" type="text" class="form-control" placeholder="Ask about test methodology, reference ranges, critical values…" onkeydown="if(event.key==='Enter')sendChat()"/>
      <button class="btn btn-primary" onclick="sendChat()"><i class="fas fa-paper-plane"></i></button>
    </div></div>
  </div>
</div>
}
<style>
.ai-hdr { color:#fff; font-weight:600; font-size:.875rem; padding:.75rem 1.25rem; border-radius:var(--radius) var(--radius) 0 0; }
.ai-result { background:#fffbeb; border-left:4px solid #d97706; padding:.9rem 1.1rem; border-radius:6px; font-size:.875rem; line-height:1.65; }
.nav-pills .nav-link { background:#f1f3f5; color:var(--text); border:none; border-radius:8px; font-size:.8rem; padding:.4rem .9rem; }
.nav-pills .nav-link.active { background:#d97706; color:#fff; }
.chat-msg { margin-bottom:.75rem; } .chat-msg.user .bubble { background:#d97706; color:#fff; border-radius:18px 18px 4px 18px; margin-left:auto; max-width:80%; }
.chat-msg.ai .bubble { background:#fff; border:1px solid #dee2e6; border-radius:18px 18px 18px 4px; max-width:88%; }
.bubble { padding:.55rem .9rem; display:inline-block; font-size:.875rem; line-height:1.5; white-space:pre-wrap; word-break:break-word; }
.chat-msg.user { text-align:right; } .spinner-sm { width:1.1rem; height:1.1rem; }
</style>
<script>
document.querySelectorAll('#aiTabs .nav-link').forEach(btn=>{btn.addEventListener('click',()=>{document.querySelectorAll('#aiTabs .nav-link').forEach(b=>b.classList.remove('active'));document.querySelectorAll('.ai-tab').forEach(t=>t.style.display='none');btn.classList.add('active');document.getElementById('tab-'+btn.dataset.tab).style.display='';});});
async function runInterpret(){
  const test=document.getElementById('r-test').value.trim();const val=document.getElementById('r-val').value.trim();const unit=document.getElementById('r-unit').value.trim();const ctx=document.getElementById('r-ctx').value.trim();
  if(!test||!val){alert('Please enter test name and value.');return;}
  const btn=document.getElementById('r-btn');const res=document.getElementById('r-res');
  const orig=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-sm"></span> Interpreting…';res.style.display='none';
  const fd=new FormData();fd.append('testName',test);fd.append('value',val);fd.append('unit',unit);fd.append('context',ctx);fd.append('__RequestVerificationToken',getToken());
  try{const r=await fetch('@Url.Action("InterpretResult","AiAssistant",new{area="LabTech"})',{method:'POST',body:fd});const d=await r.json();res.innerHTML=renderMd(d.result||'No response.');res.style.display='block';}
  catch(e){res.innerHTML='Error.';res.style.display='block';}
  finally{btn.disabled=false;btn.innerHTML=orig;}
}
async function runPanel(){
  const cond=document.getElementById('p-cond').value.trim();if(!cond){alert('Please describe the condition.');return;}
  const btn=document.getElementById('p-btn');const res=document.getElementById('p-res');
  const orig=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-sm"></span> Thinking…';res.style.display='none';
  const fd=new FormData();fd.append('condition',cond);fd.append('__RequestVerificationToken',getToken());
  try{const r=await fetch('@Url.Action("SuggestTests","AiAssistant",new{area="LabTech"})',{method:'POST',body:fd});const d=await r.json();res.innerHTML=renderMd(d.result||'No response.');res.style.display='block';}
  catch(e){res.innerHTML='Error.';res.style.display='block';}
  finally{btn.disabled=false;btn.innerHTML=orig;}
}
const chatHistory=[{role:'system',content:'You are MedCoreAI, a laboratory medicine assistant. Help lab technicians interpret results, understand reference ranges, and suggest appropriate test panels.'}];
async function sendChat(){const input=document.getElementById('chatIn');const msg=input.value.trim();if(!msg)return;appendBubble('user',escHtml(msg));chatHistory.push({role:'user',content:msg});input.value='';const t=appendBubble('ai','<span class="spinner-border spinner-sm"></span> Thinking…');try{const r=await fetch('@Url.Action("Chat","AiAssistant",new{area="LabTech"})',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':getToken()},body:JSON.stringify({messages:chatHistory})});const d=await r.json();t.querySelector('.bubble').innerHTML=renderMd(d.result||'');chatHistory.push({role:'assistant',content:d.result||''});}catch(e){t.querySelector('.bubble').textContent='Error.';}scrollChat();}
function appendBubble(r,h){const b=document.getElementById('chatBox');const d=document.createElement('div');d.className=`chat-msg ${r}`;d.innerHTML=`<div class="bubble">${h}</div>`;b.appendChild(d);scrollChat();return d;}
function scrollChat(){const b=document.getElementById('chatBox');b.scrollTop=b.scrollHeight;}
function getToken(){return document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';}
function escHtml(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function renderMd(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/^### (.+)$/gm,'<strong style="font-size:.93em;text-decoration:underline">$1</strong>').replace(/^## (.+)$/gm,'<strong style="font-size:.97em">$1</strong>').replace(/^# (.+)$/gm,'<strong style="font-size:1.02em">$1</strong>').replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>').replace(/^- (.+)$/gm,'• $1').replace(/\n/g,'<br>');}
document.addEventListener('DOMContentLoaded',()=>{const f=document.createElement('form');f.innerHTML='@Html.AntiForgeryToken()';document.body.appendChild(f);});
</script>
