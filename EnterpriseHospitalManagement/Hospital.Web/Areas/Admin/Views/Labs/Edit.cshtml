@model LabViewModel
@{ ViewData["Title"] = "Edit Lab Test"; ViewData["ShowSidebar"] = true; }
<div class="page-header">
  <div><div class="page-title">Edit Lab Test</div></div>
  <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="form-card">
  <div class="form-card-header"><h2><i class="fas fa-pen"></i> Edit Lab Test</h2></div>
  <div class="form-card-body">
    <form asp-action="Edit" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id"/>
      <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid?"none":"flex")"></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="LabNumber">Lab #</label><input asp-for="LabNumber" class="form-control" readonly/></div>
        <div class="form-group"><label class="form-label" asp-for="Status">Status</label><select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<Hospital.Models.Enums.LabTestStatus>()"></select></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="TestType">Test Type</label><input asp-for="TestType" class="form-control"/></div>
        <div class="form-group"><label class="form-label" asp-for="TestCode">Test Code</label><input asp-for="TestCode" class="form-control"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="Weight">Weight</label><input asp-for="Weight" class="form-control"/></div>
        <div class="form-group"><label class="form-label" asp-for="BloodPressure">Blood Pressure</label><input asp-for="BloodPressure" type="number" class="form-control"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="Temperature">Temperature</label><input asp-for="Temperature" type="number" class="form-control"/></div>
        <div class="form-group"><label class="form-label" asp-for="PatientId">Patient</label><select asp-for="PatientId" class="form-control" asp-items="ViewBag.Patients"></select></div>
      </div>
      <div class="form-group"><label class="form-label" asp-for="TestResult">Test Result</label><textarea asp-for="TestResult" class="form-control" rows="3"></textarea></div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial"/> }
