@model LabViewModel
@{ ViewData["Title"] = "Order Lab Test"; ViewData["ShowSidebar"] = true; }
<div class="page-header">
  <div><div class="page-title">Order Lab Test</div></div>
  <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="form-card">
  <div class="form-card-header"><h2><i class="fas fa-flask"></i> New Lab Test</h2></div>
  <div class="form-card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid?"none":"flex")"></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="LabNumber">Lab # *</label><input asp-for="LabNumber" class="form-control" readonly/></div>
        <div class="form-group"><label class="form-label" asp-for="TestType">Test Type *</label>
          <select asp-for="TestType" class="form-control"><option value="Blood Test">Blood Test</option><option value="Urine Test">Urine Test</option><option value="X-Ray">X-Ray</option><option value="MRI">MRI</option><option value="CT Scan">CT Scan</option><option value="ECG">ECG</option><option value="Ultrasound">Ultrasound</option></select></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="TestCode">Test Code *</label><input asp-for="TestCode" class="form-control"/></div>
        <div class="form-group"><label class="form-label" asp-for="PatientId">Patient *</label><select asp-for="PatientId" class="form-control" asp-items="ViewBag.Patients"><option value="">-- Select --</option></select></div>
      </div>
      <div class="form-group"><label class="form-label" asp-for="DoctorId">Referring Doctor</label><select asp-for="DoctorId" class="form-control" asp-items="ViewBag.Doctors"><option value="">-- Select --</option></select></div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Order Test</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial"/> }
