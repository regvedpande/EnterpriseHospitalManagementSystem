@model PagedResult<LabViewModel>
@{ ViewData["Title"] = "Lab Tests"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Labs"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Admin"; }
<div class="page-header">
  <div><div class="page-title">Lab Tests</div><small class="text-muted">Manage laboratory tests</small></div>
  <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Order Test</a>
</div>
<div class="table-wrapper">
  <div class="table-toolbar">
    <div class="search-input-wrap"><i class="fas fa-search"></i><input type="text" class="search-input" placeholder="Search…" oninput="filterTable('s','t')" id="s"/></div>
    <span class="text-muted" style="font-size:.8rem;">@Model.TotalCount total</span>
  </div>
  @if (!Model.Items.Any())
  { <div class="empty-state"><i class="fas fa-flask"></i><h3>No lab tests yet</h3></div> }
  else
  {
    <table id="t">
      <thead><tr><th>#</th><th>Lab #</th><th>Patient</th><th>Test</th><th>Code</th><th>Status</th><th>Date</th><th style="width:120px;">Actions</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber - 1) * Model.PageSize + 1; }
        @foreach (var l in Model.Items)
        {
          <tr><td>@(i++)</td><td><strong>@l.LabNumber</strong></td><td>@l.PatientName</td>
            <td>@l.TestType</td><td>@l.TestCode</td>
            <td><span class="badge bg-@(l.Status == Hospital.Models.Enums.LabTestStatus.Completed ? "success" : "info")">@l.Status</span></td>
            <td>@l.CreatedDate.ToString("MMM dd, yyyy")</td>
            <td><div class="td-actions">
              <a asp-action="Edit" asp-route-id="@l.Id" class="btn btn-warning btn-sm btn-icon"><i class="fas fa-pen"></i></a>
              <form id="del-@l.Id" asp-action="Delete" asp-route-id="@l.Id" method="post" style="display:inline;">@Html.AntiForgeryToken()</form>
              <button type="button" onclick="confirmDelete('del-@l.Id')" class="btn btn-danger btn-sm btn-icon"><i class="fas fa-trash"></i></button>
            </div></td></tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
