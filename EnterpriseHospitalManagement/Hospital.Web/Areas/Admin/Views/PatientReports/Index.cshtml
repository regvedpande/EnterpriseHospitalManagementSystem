@model PagedResult<PatientReportViewModel>
@{ ViewData["Title"] = "Patient Reports"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "PatientReports"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Admin"; }
<div class="page-header">
  <div><div class="page-title">Patient Reports</div><small class="text-muted">View all medical reports</small></div>
</div>
<div class="table-wrapper">
  <div class="table-toolbar">
    <div class="search-input-wrap"><i class="fas fa-search"></i><input type="text" class="search-input" placeholder="Search…" oninput="filterTable('s','t')" id="s"/></div>
    <span class="text-muted" style="font-size:.8rem;">@Model.TotalCount total</span>
  </div>
  @if (!Model.Items.Any()) { <div class="empty-state"><i class="fas fa-file-medical"></i><h3>No reports yet</h3></div> }
  else {
    <table id="t">
      <thead><tr><th>#</th><th>Patient</th><th>Doctor</th><th>Diagnosis</th><th>Date</th><th style="width:120px;">Actions</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber - 1) * Model.PageSize + 1; }
        @foreach (var r in Model.Items) {
          <tr><td>@(i++)</td><td><strong>@r.PatientName</strong></td><td>@r.DoctorName</td>
            <td>@r.Diagnose</td><td>@r.CreatedDate.ToString("MMM dd, yyyy")</td>
            <td><div class="td-actions">
              <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-info btn-sm btn-icon"><i class="fas fa-eye"></i></a>
              <form id="del-@r.Id" asp-action="Delete" asp-route-id="@r.Id" method="post" style="display:inline;">@Html.AntiForgeryToken()</form>
              <button type="button" onclick="confirmDelete('del-@r.Id')" class="btn btn-danger btn-sm btn-icon"><i class="fas fa-trash"></i></button>
            </div></td></tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
