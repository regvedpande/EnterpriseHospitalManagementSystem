@model PatientReportViewModel
@{ ViewData["Title"] = "Report Details"; ViewData["ShowSidebar"] = true; }
<div class="page-header"><div><div class="page-title">Patient Report</div></div>
  <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div>
<div class="form-card">
  <div class="form-card-header"><h2><i class="fas fa-file-medical"></i> Report Details</h2></div>
  <div class="form-card-body">
    <div class="form-row">
      <div class="form-group"><label class="form-label">Patient</label><p class="form-control-plaintext"><strong>@Model.PatientName</strong></p></div>
      <div class="form-group"><label class="form-label">Doctor</label><p class="form-control-plaintext"><strong>@Model.DoctorName</strong></p></div>
    </div>
    <div class="form-group"><label class="form-label">Diagnosis</label><p class="form-control-plaintext">@Model.Diagnose</p></div>
    <div class="form-group"><label class="form-label">Notes</label><p class="form-control-plaintext">@(Model.Notes ?? "—")</p></div>
    <div class="form-group"><label class="form-label">Date</label><p class="form-control-plaintext">@Model.CreatedDate.ToString("MMMM dd, yyyy")</p></div>
    @if (Model.Prescriptions.Any()) {
      <h4 class="mt-4">Prescribed Medicines</h4>
      <table><thead><tr><th>Medicine</th><th>Dosage</th><th>Duration (days)</th><th>Instructions</th></tr></thead>
        <tbody>
          @foreach (var p in Model.Prescriptions) {
            <tr><td><strong>@p.MedicineName</strong></td><td>@p.Dosage</td><td>@p.Duration</td><td>@p.Instructions</td></tr>
          }
        </tbody>
      </table>
    }
  </div>
</div>
