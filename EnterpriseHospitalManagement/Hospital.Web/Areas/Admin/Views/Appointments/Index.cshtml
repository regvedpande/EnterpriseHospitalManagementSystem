@model PagedResult<AppointmentViewModel>
@{ ViewData["Title"] = "Appointments"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Appointments"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Admin"; }
<div class="page-header">
  <div><div class="page-title">Appointments</div><small class="text-muted">Manage all appointments</small></div>
  <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> New Appointment</a>
</div>
<div class="table-wrapper">
  <div class="table-toolbar">
    <div class="search-input-wrap"><i class="fas fa-search"></i>
      <input type="text" class="search-input" placeholder="Search…" oninput="filterTable('s','t')" id="s"/>
    </div>
    <span class="text-muted" style="font-size:.8rem;">@Model.TotalCount total</span>
  </div>
  @if (!Model.Items.Any())
  { <div class="empty-state"><i class="fas fa-calendar-check"></i><h3>No appointments yet</h3>
      <a asp-action="Create" class="btn btn-primary mt-2"><i class="fas fa-plus"></i> Create</a></div> }
  else
  {
    <table id="t">
      <thead><tr><th>#</th><th>Number</th><th>Patient</th><th>Doctor</th><th>Date</th><th>Type</th><th>Status</th><th style="width:120px;">Actions</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber - 1) * Model.PageSize + 1; }
        @foreach (var a in Model.Items)
        {
          <tr>
            <td>@(i++)</td><td><strong>@a.Number</strong></td>
            <td>@a.PatientName</td><td>@a.DoctorName</td>
            <td>@a.AppointmentDate.ToString("MMM dd, yyyy hh:mm tt")</td>
            <td>@a.Type</td>
            <td><span class="badge bg-@(a.Status == Hospital.Models.Enums.AppointmentStatus.Completed ? "success" : a.Status == Hospital.Models.Enums.AppointmentStatus.Cancelled ? "danger" : "primary")">@a.Status</span></td>
            <td><div class="td-actions">
              <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-warning btn-sm btn-icon"><i class="fas fa-pen"></i></a>
              <form id="del-@a.Id" asp-action="Delete" asp-route-id="@a.Id" method="post" style="display:inline;">@Html.AntiForgeryToken()</form>
              <button type="button" onclick="confirmDelete('del-@a.Id')" class="btn btn-danger btn-sm btn-icon"><i class="fas fa-trash"></i></button>
            </div></td>
          </tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
