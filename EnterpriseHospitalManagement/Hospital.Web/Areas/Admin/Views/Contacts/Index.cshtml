@model Hospital.ViewModels.PagedResult<Hospital.ViewModels.ContactViewModel>
@{
    ViewData["Title"]       = "Contacts";
    ViewData["ShowSidebar"] = true;
    ViewData["Page"]        = Model.PageNumber;
    ViewData["TotalPages"]  = Model.TotalPages;
    ViewData["Size"]        = Model.PageSize;
    ViewData["TotalCount"]  = Model.TotalCount;
    ViewData["PagCtrl"]     = "Contacts";
    ViewData["PagAction"]   = "Index";
    ViewData["PagArea"]     = "Admin";
}
<div class="page-header">
  <div><div class="page-title">Contacts</div><small class="text-muted">Manage contact directory</small></div>
  <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Add Contact</a>
</div>
<div class="table-wrapper">
  <div class="table-toolbar">
    <div class="search-input-wrap">
      <i class="fas fa-search"></i>
      <input type="text" class="search-input" placeholder="Search contacts…"
             oninput="filterTable('cSearch','cTable')" id="cSearch"/>
    </div>
    <span class="text-muted" style="font-size:.8rem;">@Model.TotalCount total</span>
  </div>
  @if (!Model.Items.Any())
  {
    <div class="empty-state"><i class="fas fa-address-book"></i><h3>No contacts yet</h3>
      <a asp-action="Create" class="btn btn-primary mt-2"><i class="fas fa-plus"></i> Add Contact</a>
    </div>
  }
  else
  {
    <table id="cTable">
      <thead><tr><th>#</th><th>Name</th><th>Phone</th><th>Email</th><th>Hospital</th><th style="width:120px;">Actions</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber - 1) * Model.PageSize + 1; }
        @foreach (var c in Model.Items)
        {
          <tr>
            <td><span class="text-muted">@(i++)</span></td>
            <td><strong>@c.Name</strong></td>
            <td>@c.PhoneNumber</td>
            <td>@c.Email</td>
            <td>@c.HospitalName</td>
            <td>
              <div class="td-actions">
                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-warning btn-sm btn-icon"><i class="fas fa-pen"></i></a>
                <form id="del-c-@c.Id" asp-action="Delete" asp-route-id="@c.Id" method="post" style="display:inline;">@Html.AntiForgeryToken()</form>
                <button type="button" onclick="confirmDelete('del-c-@c.Id')" class="btn btn-danger btn-sm btn-icon"><i class="fas fa-trash"></i></button>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
