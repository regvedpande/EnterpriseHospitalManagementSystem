@model BillViewModel
@{ ViewData["Title"] = "New Bill"; ViewData["ShowSidebar"] = true; }
<div class="page-header">
  <div><div class="page-title">New Bill</div></div>
  <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="form-card">
  <div class="form-card-header"><h2><i class="fas fa-file-invoice-dollar"></i> New Bill</h2></div>
  <div class="form-card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid?"none":"flex")"></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="BillNumber">Bill #</label><input asp-for="BillNumber" class="form-control" readonly/></div>
        <div class="form-group"><label class="form-label" asp-for="PatientId">Patient *</label><select asp-for="PatientId" class="form-control" asp-items="ViewBag.Patients"><option value="">-- Select --</option></select></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="DoctorCharge">Doctor Charge</label><input asp-for="DoctorCharge" type="number" step="0.01" class="form-control"/></div>
        <div class="form-group"><label class="form-label" asp-for="MedicineCharge">Medicine Charge</label><input asp-for="MedicineCharge" type="number" step="0.01" class="form-control"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="RoomCharge">Room Charge</label><input asp-for="RoomCharge" type="number" step="0.01" class="form-control"/></div>
        <div class="form-group"><label class="form-label" asp-for="OperationCharge">Operation Charge</label><input asp-for="OperationCharge" type="number" step="0.01" class="form-control"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="NursingCharge">Nursing Charge</label><input asp-for="NursingCharge" type="number" step="0.01" class="form-control"/></div>
        <div class="form-group"><label class="form-label" asp-for="LabCharge">Lab Charge</label><input asp-for="LabCharge" type="number" step="0.01" class="form-control"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="NoOfDays">No. of Days</label><input asp-for="NoOfDays" type="number" class="form-control"/></div>
        <div class="form-group"><label class="form-label" asp-for="Advance">Advance Paid</label><input asp-for="Advance" type="number" step="0.01" class="form-control"/></div>
      </div>
      <div class="form-group"><label class="form-label" asp-for="InsuranceId">Insurance (optional)</label><select asp-for="InsuranceId" class="form-control" asp-items="ViewBag.Insurances"><option value="">-- None --</option></select></div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create Bill</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial"/> }
