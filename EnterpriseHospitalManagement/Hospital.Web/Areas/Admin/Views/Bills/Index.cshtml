@model PagedResult<BillViewModel>
@{ ViewData["Title"] = "Bills"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Bills"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Admin"; }
<div class="page-header">
  <div><div class="page-title">Bills</div><small class="text-muted">Manage patient billing</small></div>
  <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> New Bill</a>
</div>
<div class="table-wrapper">
  <div class="table-toolbar">
    <div class="search-input-wrap"><i class="fas fa-search"></i>
      <input type="text" class="search-input" placeholder="Search…" oninput="filterTable('s','t')" id="s"/></div>
    <span class="text-muted" style="font-size:.8rem;">@Model.TotalCount total</span>
  </div>
  @if (!Model.Items.Any())
  { <div class="empty-state"><i class="fas fa-file-invoice-dollar"></i><h3>No bills yet</h3>
      <a asp-action="Create" class="btn btn-primary mt-2"><i class="fas fa-plus"></i> Create</a></div> }
  else
  {
    <table id="t">
      <thead><tr><th>#</th><th>Bill #</th><th>Patient</th><th>Total</th><th>Status</th><th>Date</th><th style="width:120px;">Actions</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber - 1) * Model.PageSize + 1; }
        @foreach (var b in Model.Items)
        {
          <tr>
            <td>@(i++)</td><td><strong>@b.BillNumber</strong></td>
            <td>@b.PatientName</td><td>@b.TotalBill.ToString("C")</td>
            <td>@{ var ab = b.Status==Hospital.Models.Enums.BillStatus.Paid?"badge-success":b.Status==Hospital.Models.Enums.BillStatus.Overdue?"badge-danger":b.Status==Hospital.Models.Enums.BillStatus.Cancelled?"badge-danger":b.Status==Hospital.Models.Enums.BillStatus.PartiallyPaid?"badge-warning":"badge-info"; }<span class="badge @ab">@b.Status</span></td>
            <td>@b.CreatedDate.ToString("MMM dd, yyyy")</td>
            <td><div class="td-actions">
              <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-warning btn-sm btn-icon"><i class="fas fa-pen"></i></a>
              <form id="del-@b.Id" asp-action="Delete" asp-route-id="@b.Id" method="post" style="display:inline;">@Html.AntiForgeryToken()</form>
              <button type="button" onclick="confirmDelete('del-@b.Id')" class="btn btn-danger btn-sm btn-icon"><i class="fas fa-trash"></i></button>
            </div></td>
          </tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
