@{ ViewData["Title"] = "Upload Document"; ViewData["ShowSidebar"] = true; }
<div class="page-header">
  <div><div class="page-title">Upload Document</div></div>
  <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Back</a>
</div>
<div class="form-card">
  <form asp-action="Upload" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid?"none":"flex")"></div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Patient <span class="text-danger">*</span></label>
        <select name="patientId" class="form-control" required>
          <option value="">— Select patient —</option>
          @foreach (var p in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Patients)
          {
            <option value="@p.Value">@p.Text</option>
          }
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Document Type</label>
        <select name="documentType" class="form-control">
          @foreach (var t in (string[])ViewBag.DocumentTypes)
          {
            <option value="@t">@t</option>
          }
        </select>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">File <span class="text-danger">*</span></label>
      <input type="file" name="file" class="form-control" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.xlsx,.csv" required/>
      <small class="form-text text-muted">Accepted: PDF, Word, Images, Excel, CSV — Max 20 MB</small>
    </div>

    <div class="form-group">
      <label class="form-label">Description <span style="color:var(--text-muted)">(optional)</span></label>
      <textarea name="description" class="form-control" rows="3" placeholder="Additional notes about this document..."></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><i class="fas fa-upload"></i> Upload</button>
      <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
