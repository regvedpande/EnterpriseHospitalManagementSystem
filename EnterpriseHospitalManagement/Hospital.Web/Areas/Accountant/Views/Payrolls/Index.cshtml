@model PagedResult<PayrollViewModel>
@{ ViewData["Title"] = "Payroll"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Payrolls"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Accountant"; }
<div class="page-header">
  <div><div class="page-title">Payroll</div></div>
  <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> New Payroll</a>
</div>
<div class="table-wrapper">
  <div class="table-toolbar">
    <div class="search-input-wrap"><i class="fas fa-search"></i><input type="text" class="search-input" id="s" placeholder="Search payroll…" oninput="filterTable('s','t')"/></div>
    <span class="text-muted" style="font-size:.8rem;">@Model.TotalCount record(s)</span>
  </div>
  @if (!Model.Items.Any()) { <div class="empty-state"><i class="fas fa-money-check-alt"></i><h3>No payroll records</h3></div> }
  else {
    <table id="t">
      <thead><tr><th>#</th><th>Employee</th><th>Period</th><th>Net Salary</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber-1)*Model.PageSize+1; }
        @foreach (var p in Model.Items) {
          <tr><td>@(i++)</td><td><strong>@p.EmployeeName</strong></td>
            <td>@p.PayPeriodStart.ToString("MMM dd") - @p.PayPeriodEnd.ToString("MMM dd, yyyy")</td>
            <td>@p.NetSalary.ToString("C")</td>
            <td>@{ var ps = p.Status==Hospital.Models.Enums.PayrollStatus.Paid?"badge-success":p.Status==Hospital.Models.Enums.PayrollStatus.Approved?"badge-info":"badge-warning"; }<span class="badge @ps">@p.Status</span></td>
            <td><a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-warning btn-sm btn-icon"><i class="fas fa-pen"></i></a></td></tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
