@{
    ViewData["Title"]       = "Pharmacy AI Assistant";
    ViewData["ShowSidebar"] = true;
    bool cfg = (bool)(ViewBag.IsConfigured ?? false);
}
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-robot" style="color:#f5576c;"></i> Pharmacy AI Assistant</div>
    <small class="text-muted">Drug interactions · Dosage guidance · Therapeutic substitution</small>
  </div>
</div>
@if (!cfg) { <div class="alert alert-warning"><i class="fas fa-exclamation-triangle"></i> AI service not configured.</div> }
else {
<ul class="nav nav-pills mb-3 gap-2 flex-wrap" id="aiTabs">
  <li class="nav-item"><button class="nav-link active" data-tab="interaction"><i class="fas fa-exclamation-circle"></i> Drug Interactions</button></li>
  <li class="nav-item"><button class="nav-link" data-tab="dosage"><i class="fas fa-syringe"></i> Dosage Guide</button></li>
  <li class="nav-item"><button class="nav-link" data-tab="substitute"><i class="fas fa-exchange-alt"></i> Substitutes</button></li>
  <li class="nav-item"><button class="nav-link" data-tab="chat"><i class="fas fa-comments"></i> Pharmacy Chat</button></li>
</ul>

<div class="ai-tab" id="tab-interaction">
  <div class="card"><div class="card-header ai-hdr" style="background:linear-gradient(135deg,#f7971e,#ffd200);">
    <i class="fas fa-exclamation-circle"></i> Drug Interaction Checker
  </div><div class="card-body d-flex flex-column gap-3">
    <label class="text-muted small">Enter one medicine per line with dose if known</label>
    <textarea id="i-meds" class="form-control" rows="6" placeholder="Warfarin 5mg&#10;Aspirin 100mg&#10;Omeprazole 20mg&#10;Clopidogrel 75mg&#10;Atorvastatin 40mg"></textarea>
    <button class="btn btn-warning" id="i-btn" onclick="runTool('CheckInteraction','medicines','i-meds','i-res','i-btn')">
      <i class="fas fa-search"></i> Check Interactions
    </button>
    <div id="i-res" class="ai-result" style="display:none;border-color:#f7971e;"></div>
  </div></div>
</div>

<div class="ai-tab" id="tab-dosage" style="display:none;">
  <div class="card"><div class="card-header ai-hdr" style="background:linear-gradient(135deg,#f5576c,#f093fb);">
    <i class="fas fa-syringe"></i> Dosage Guide
  </div><div class="card-body d-flex flex-column gap-3">
    <input id="d-drug" class="form-control" placeholder="Drug name e.g. Amoxicillin, Metformin 500mg"/>
    <textarea id="d-pat" class="form-control" rows="2" placeholder="Patient info e.g. 65yo male, CKD stage 3, weight 70kg, on dialysis"></textarea>
    <button class="btn btn-danger" id="d-btn" onclick="runDosage()">
      <i class="fas fa-prescription"></i> Get Dosage Guide
    </button>
    <div id="d-res" class="ai-result" style="display:none;border-color:#f5576c;"></div>
  </div></div>
</div>

<div class="ai-tab" id="tab-substitute" style="display:none;">
  <div class="card"><div class="card-header ai-hdr" style="background:linear-gradient(135deg,#4facfe,#00f2fe);">
    <i class="fas fa-exchange-alt"></i> Therapeutic Substitution
  </div><div class="card-body d-flex flex-column gap-3">
    <input id="s-drug" class="form-control" placeholder="Drug to substitute e.g. Atenolol 50mg"/>
    <input id="s-reason" class="form-control" placeholder="Reason for substitution e.g. patient allergy, unavailable, cost"/>
    <button class="btn btn-info" id="s-btn" onclick="runSubstitute()">
      <i class="fas fa-exchange-alt"></i> Find Substitutes
    </button>
    <div id="s-res" class="ai-result" style="display:none;border-color:#4facfe;"></div>
  </div></div>
</div>

<div class="ai-tab" id="tab-chat" style="display:none;">
  <div class="card" style="height:520px;display:flex;flex-direction:column;">
    <div class="card-header ai-hdr" style="background:linear-gradient(135deg,#f5576c,#667eea);">
      <i class="fas fa-comments"></i> Pharmacy Q&amp;A Chat
    </div>
    <div id="chatBox" class="flex-grow-1 p-3" style="overflow-y:auto;background:#f8f9fa;"></div>
    <div class="card-footer p-2"><div class="input-group">
      <input id="chatIn" type="text" class="form-control" placeholder="Ask about any drug, interaction, or pharmacy question…" onkeydown="if(event.key==='Enter')sendChat()"/>
      <button class="btn btn-primary" onclick="sendChat()"><i class="fas fa-paper-plane"></i></button>
    </div></div>
  </div>
</div>
}

<style>
.ai-hdr { color:#fff; font-weight:600; font-size:.875rem; padding:.75rem 1.25rem; border-radius:var(--radius) var(--radius) 0 0; }
.ai-result { background:#fffbf0; border-left:4px solid #f7971e; padding:.9rem 1.1rem; border-radius:6px; font-size:.875rem; line-height:1.65; }
.nav-pills .nav-link { background:#f1f3f5; color:var(--text); border:none; border-radius:8px; font-size:.8rem; padding:.4rem .9rem; }
.nav-pills .nav-link.active { background:#f5576c; color:#fff; }
.chat-msg { margin-bottom:.75rem; }
.chat-msg.user .bubble { background:#f5576c; color:#fff; border-radius:18px 18px 4px 18px; margin-left:auto; max-width:80%; }
.chat-msg.ai .bubble   { background:#fff; border:1px solid #dee2e6; border-radius:18px 18px 18px 4px; max-width:88%; }
.bubble { padding:.55rem .9rem; display:inline-block; font-size:.875rem; line-height:1.5; white-space:pre-wrap; word-break:break-word; }
.chat-msg.user { text-align:right; }
.spinner-sm { width:1.1rem; height:1.1rem; }
</style>
<script>
document.querySelectorAll('#aiTabs .nav-link').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('#aiTabs .nav-link').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.ai-tab').forEach(t=>t.style.display='none');
    btn.classList.add('active');
    document.getElementById('tab-'+btn.dataset.tab).style.display='';
  });
});
async function runTool(action, field, inputId, resId, btnId) {
  const val = document.getElementById(inputId).value.trim();
  if (!val) { alert('Please fill in the input.'); return; }
  const btn = document.getElementById(btnId);
  const res = document.getElementById(resId);
  const orig = btn.innerHTML; btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-sm"></span> Loading…';
  res.style.display='none';
  const fd = new FormData(); fd.append(field, val); fd.append('__RequestVerificationToken', getToken());
  try {
    const r = await fetch('@Url.Action("CheckInteraction","AiAssistant",new{area="Pharmacist"})', {method:'POST',body:fd});
    const d = await r.json(); res.innerHTML=renderMd(d.result||'No response.'); res.style.display='block';
  } catch(e) { res.innerHTML='Error.'; res.style.display='block'; }
  finally { btn.disabled=false; btn.innerHTML=orig; }
}
async function runDosage() {
  const drug=document.getElementById('d-drug').value.trim(); const pat=document.getElementById('d-pat').value.trim();
  if (!drug) { alert('Enter a drug name.'); return; }
  const btn=document.getElementById('d-btn'); const res=document.getElementById('d-res');
  const orig=btn.innerHTML; btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-sm"></span> Loading…'; res.style.display='none';
  const fd=new FormData(); fd.append('drug',drug); fd.append('patientInfo',pat); fd.append('__RequestVerificationToken',getToken());
  try { const r=await fetch('@Url.Action("DosageGuide","AiAssistant",new{area="Pharmacist"})',{method:'POST',body:fd}); const d=await r.json(); res.innerHTML=renderMd(d.result||'No response.'); res.style.display='block'; }
  catch(e){ res.innerHTML='Error.'; res.style.display='block'; }
  finally { btn.disabled=false; btn.innerHTML=orig; }
}
async function runSubstitute() {
  const drug=document.getElementById('s-drug').value.trim(); const reason=document.getElementById('s-reason').value.trim();
  if (!drug) { alert('Enter a drug name.'); return; }
  const btn=document.getElementById('s-btn'); const res=document.getElementById('s-res');
  const orig=btn.innerHTML; btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-sm"></span> Loading…'; res.style.display='none';
  const fd=new FormData(); fd.append('drug',drug); fd.append('reason',reason); fd.append('__RequestVerificationToken',getToken());
  try { const r=await fetch('@Url.Action("FindSubstitute","AiAssistant",new{area="Pharmacist"})',{method:'POST',body:fd}); const d=await r.json(); res.innerHTML=renderMd(d.result||'No response.'); res.style.display='block'; }
  catch(e){ res.innerHTML='Error.'; res.style.display='block'; }
  finally { btn.disabled=false; btn.innerHTML=orig; }
}
const chatHistory=[{role:'system',content:'You are MedCoreAI, a clinical pharmacy assistant. Answer pharmacy questions with precision about drugs, doses, interactions, and counselling.'}];
async function sendChat(){
  const input=document.getElementById('chatIn'); const msg=input.value.trim(); if(!msg) return;
  appendBubble('user',escHtml(msg)); chatHistory.push({role:'user',content:msg}); input.value='';
  const t=appendBubble('ai','<span class="spinner-border spinner-sm"></span> Thinking…');
  try { const r=await fetch('@Url.Action("Chat","AiAssistant",new{area="Pharmacist"})',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':getToken()},body:JSON.stringify({messages:chatHistory})}); const d=await r.json(); t.querySelector('.bubble').innerHTML=renderMd(d.result||''); chatHistory.push({role:'assistant',content:d.result||''}); }
  catch(e){ t.querySelector('.bubble').textContent='Error.'; }
  scrollChat();
}
function appendBubble(r,h){const b=document.getElementById('chatBox');const d=document.createElement('div');d.className=`chat-msg ${r}`;d.innerHTML=`<div class="bubble">${h}</div>`;b.appendChild(d);scrollChat();return d;}
function scrollChat(){const b=document.getElementById('chatBox');b.scrollTop=b.scrollHeight;}
function getToken(){return document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';}
function escHtml(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function renderMd(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/^### (.+)$/gm,'<strong style="font-size:.93em;text-decoration:underline">$1</strong>').replace(/^## (.+)$/gm,'<strong style="font-size:.97em">$1</strong>').replace(/^# (.+)$/gm,'<strong style="font-size:1.02em">$1</strong>').replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>').replace(/^- (.+)$/gm,'• $1').replace(/\n/g,'<br>');}
document.addEventListener('DOMContentLoaded',()=>{const f=document.createElement('form');f.innerHTML='@Html.AntiForgeryToken()';document.body.appendChild(f);});
</script>
