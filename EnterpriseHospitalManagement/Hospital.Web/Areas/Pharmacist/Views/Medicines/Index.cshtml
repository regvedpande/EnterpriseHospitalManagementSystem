@model PagedResult<MedicineViewModel>
@{ ViewData["Title"] = "Medicines"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Medicines"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Pharmacist"; }
<div class="page-header">
  <div><div class="page-title">Medicines</div></div>
  <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Add Medicine</a>
</div>
<div class="table-wrapper">
  @if (!Model.Items.Any()) { <div class="empty-state"><i class="fas fa-pills"></i><h3>No medicines</h3></div> }
  else {
    <table id="t">
      <thead><tr><th>#</th><th>Name</th><th>Type</th><th>Cost</th><th>Actions</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber-1)*Model.PageSize+1; }
        @foreach (var m in Model.Items) {
          <tr><td>@(i++)</td><td><strong>@m.Name</strong></td><td>@m.Type</td><td>@m.Cost.ToString("C")</td>
            <td>
              <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-warning btn-sm btn-icon"><i class="fas fa-pen"></i></a>
              <form asp-action="Delete" asp-route-id="@m.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this medicine?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-sm btn-icon"><i class="fas fa-trash"></i></button>
              </form>
            </td></tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
