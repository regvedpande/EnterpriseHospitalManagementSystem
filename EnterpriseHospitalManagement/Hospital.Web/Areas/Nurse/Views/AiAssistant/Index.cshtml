@{
    ViewData["Title"]       = "Nursing AI Assistant";
    ViewData["ShowSidebar"] = true;
    bool cfg = (bool)(ViewBag.IsConfigured ?? false);
}
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-robot" style="color:#7c3aed;"></i> Nursing AI Assistant</div>
    <small class="text-muted">Vitals interpretation · Care plans · Clinical guidance</small>
  </div>
</div>
@if (!cfg) { <div class="alert alert-warning"><i class="fas fa-exclamation-triangle"></i> AI service not configured.</div> }
else {
<ul class="nav nav-pills mb-3 gap-2 flex-wrap" id="aiTabs">
  <li class="nav-item"><button class="nav-link active" data-tab="vitals"><i class="fas fa-heartbeat"></i> Vitals Interpreter</button></li>
  <li class="nav-item"><button class="nav-link" data-tab="careplan"><i class="fas fa-clipboard-list"></i> Care Plan</button></li>
  <li class="nav-item"><button class="nav-link" data-tab="chat"><i class="fas fa-comments"></i> Nursing Chat</button></li>
</ul>

<div class="ai-tab" id="tab-vitals">
  <div class="card"><div class="card-header ai-hdr" style="background:linear-gradient(135deg,#7c3aed,#a78bfa);">
    <i class="fas fa-heartbeat"></i> Vitals Interpretation &amp; Alert
  </div><div class="card-body d-flex flex-column gap-3">
    <label class="text-muted small">Enter patient vitals (BP, HR, Temp, SpO2, RR, etc.)</label>
    <textarea id="v-vitals" class="form-control" rows="4" placeholder="BP: 180/110 mmHg&#10;Heart Rate: 110 bpm&#10;Temperature: 38.9°C&#10;SpO2: 94%&#10;Respiratory Rate: 24/min&#10;GCS: 14/15"></textarea>
    <textarea id="v-ctx" class="form-control" rows="2" placeholder="Patient context e.g. 72yo female, post-op day 2 hip replacement, history of hypertension"></textarea>
    <button class="btn btn-purple" id="v-btn" onclick="runVitals()">
      <i class="fas fa-stethoscope"></i> Interpret Vitals
    </button>
    <div id="v-res" class="ai-result" style="display:none;border-color:#7c3aed;background:#f5f3ff;"></div>
  </div></div>
</div>

<div class="ai-tab" id="tab-careplan" style="display:none;">
  <div class="card"><div class="card-header ai-hdr" style="background:linear-gradient(135deg,#059669,#34d399);">
    <i class="fas fa-clipboard-list"></i> Nursing Care Plan Generator
  </div><div class="card-body d-flex flex-column gap-3">
    <textarea id="c-cond" class="form-control" rows="4" placeholder="Describe patient condition and medical diagnosis…&#10;e.g. 58yo male admitted with acute COPD exacerbation, SpO2 88% on air, increased work of breathing, anxious, on salbutamol nebulisers"></textarea>
    <button class="btn btn-success" id="c-btn" onclick="runCarePlan()">
      <i class="fas fa-file-medical"></i> Generate Care Plan
    </button>
    <div id="c-res" class="ai-result" style="display:none;border-color:#059669;background:#f0fdf4;"></div>
  </div></div>
</div>

<div class="ai-tab" id="tab-chat" style="display:none;">
  <div class="card" style="height:520px;display:flex;flex-direction:column;">
    <div class="card-header ai-hdr" style="background:linear-gradient(135deg,#7c3aed,#059669);">
      <i class="fas fa-comments"></i> Nursing Q&amp;A Chat
    </div>
    <div id="chatBox" class="flex-grow-1 p-3" style="overflow-y:auto;background:#f8f9fa;"></div>
    <div class="card-footer p-2"><div class="input-group">
      <input id="chatIn" type="text" class="form-control" placeholder="Ask about patient care, procedures, medications…" onkeydown="if(event.key==='Enter')sendChat()"/>
      <button class="btn btn-primary" onclick="sendChat()"><i class="fas fa-paper-plane"></i></button>
    </div></div>
  </div>
</div>
}
<style>
.ai-hdr { color:#fff; font-weight:600; font-size:.875rem; padding:.75rem 1.25rem; border-radius:var(--radius) var(--radius) 0 0; }
.ai-result { background:#f5f3ff; border-left:4px solid #7c3aed; padding:.9rem 1.1rem; border-radius:6px; font-size:.875rem; line-height:1.65; }
.btn-purple { background:#7c3aed; color:#fff; } .btn-purple:hover { background:#6d28d9; color:#fff; }
.nav-pills .nav-link { background:#f1f3f5; color:var(--text); border:none; border-radius:8px; font-size:.8rem; padding:.4rem .9rem; }
.nav-pills .nav-link.active { background:#7c3aed; color:#fff; }
.chat-msg { margin-bottom:.75rem; } .chat-msg.user .bubble { background:#7c3aed; color:#fff; border-radius:18px 18px 4px 18px; margin-left:auto; max-width:80%; }
.chat-msg.ai .bubble { background:#fff; border:1px solid #dee2e6; border-radius:18px 18px 18px 4px; max-width:88%; }
.bubble { padding:.55rem .9rem; display:inline-block; font-size:.875rem; line-height:1.5; white-space:pre-wrap; word-break:break-word; }
.chat-msg.user { text-align:right; } .spinner-sm { width:1.1rem; height:1.1rem; }
</style>
<script>
document.querySelectorAll('#aiTabs .nav-link').forEach(btn=>{btn.addEventListener('click',()=>{document.querySelectorAll('#aiTabs .nav-link').forEach(b=>b.classList.remove('active'));document.querySelectorAll('.ai-tab').forEach(t=>t.style.display='none');btn.classList.add('active');document.getElementById('tab-'+btn.dataset.tab).style.display='';});});
async function runVitals(){
  const vitals=document.getElementById('v-vitals').value.trim();const ctx=document.getElementById('v-ctx').value.trim();
  if(!vitals){alert('Please enter vitals.');return;}
  const btn=document.getElementById('v-btn');const res=document.getElementById('v-res');
  const orig=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-sm"></span> Analysing…';res.style.display='none';
  const fd=new FormData();fd.append('vitals',vitals);fd.append('context',ctx);fd.append('__RequestVerificationToken',getToken());
  try{const r=await fetch('@Url.Action("InterpretVitals","AiAssistant",new{area="Nurse"})',{method:'POST',body:fd});const d=await r.json();res.innerHTML=renderMd(d.result||'No response.');res.style.display='block';}
  catch(e){res.innerHTML='Error.';res.style.display='block';}
  finally{btn.disabled=false;btn.innerHTML=orig;}
}
async function runCarePlan(){
  const cond=document.getElementById('c-cond').value.trim();
  if(!cond){alert('Please describe the condition.');return;}
  const btn=document.getElementById('c-btn');const res=document.getElementById('c-res');
  const orig=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-sm"></span> Generating…';res.style.display='none';
  const fd=new FormData();fd.append('condition',cond);fd.append('__RequestVerificationToken',getToken());
  try{const r=await fetch('@Url.Action("CarePlan","AiAssistant",new{area="Nurse"})',{method:'POST',body:fd});const d=await r.json();res.innerHTML=renderMd(d.result||'No response.');res.style.display='block';}
  catch(e){res.innerHTML='Error.';res.style.display='block';}
  finally{btn.disabled=false;btn.innerHTML=orig;}
}
const chatHistory=[{role:'system',content:'You are MedCoreAI, a nursing support assistant. Help nurses with patient care, vitals, clinical procedures, and care planning.'}];
async function sendChat(){const input=document.getElementById('chatIn');const msg=input.value.trim();if(!msg)return;appendBubble('user',escHtml(msg));chatHistory.push({role:'user',content:msg});input.value='';const t=appendBubble('ai','<span class="spinner-border spinner-sm"></span> Thinking…');try{const r=await fetch('@Url.Action("Chat","AiAssistant",new{area="Nurse"})',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':getToken()},body:JSON.stringify({messages:chatHistory})});const d=await r.json();t.querySelector('.bubble').innerHTML=renderMd(d.result||'');chatHistory.push({role:'assistant',content:d.result||''});}catch(e){t.querySelector('.bubble').textContent='Error.';}scrollChat();}
function appendBubble(r,h){const b=document.getElementById('chatBox');const d=document.createElement('div');d.className=`chat-msg ${r}`;d.innerHTML=`<div class="bubble">${h}</div>`;b.appendChild(d);scrollChat();return d;}
function scrollChat(){const b=document.getElementById('chatBox');b.scrollTop=b.scrollHeight;}
function getToken(){return document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';}
function escHtml(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function renderMd(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/^### (.+)$/gm,'<strong style="font-size:.93em;text-decoration:underline">$1</strong>').replace(/^## (.+)$/gm,'<strong style="font-size:.97em">$1</strong>').replace(/^# (.+)$/gm,'<strong style="font-size:1.02em">$1</strong>').replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>').replace(/^- (.+)$/gm,'• $1').replace(/\n/g,'<br>');}
document.addEventListener('DOMContentLoaded',()=>{const f=document.createElement('form');f.innerHTML='@Html.AntiForgeryToken()';document.body.appendChild(f);});
</script>
