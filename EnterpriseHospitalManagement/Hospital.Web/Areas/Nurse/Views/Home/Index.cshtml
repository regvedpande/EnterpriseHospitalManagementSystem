@{
    ViewData["Title"]       = "Nurse Dashboard";
    ViewData["ShowSidebar"] = true;
    int apptCount    = (int)(ViewBag.AppointmentCount ?? 0);
    int patientCount = (int)(ViewBag.PatientCount     ?? 0);
    int roomCount    = (int)(ViewBag.RoomCount        ?? 0);
    string name = User.Identity?.Name ?? "Nurse";
}

<div class="welcome-banner">
  <div>
    <h2>Good day, @name</h2>
    <p>Nurse Station — Monitor patients and manage appointment schedules.</p>
  </div>
  <div class="welcome-actions">
    <a asp-area="Nurse" asp-controller="Appointments" asp-action="Index" class="btn btn-white">
      <i class="fas fa-calendar-check"></i> View All Appointments
    </a>
  </div>
</div>

<div class="stats-grid">
  <a class="stat-card stat-link" asp-area="Nurse" asp-controller="Appointments" asp-action="Index">
    <div class="stat-icon blue"><i class="fas fa-calendar-check"></i></div>
    <div class="stat-body">
      <div class="stat-value">@apptCount</div>
      <div class="stat-label">Total Appointments</div>
    </div>
    <i class="fas fa-chevron-right stat-arrow"></i>
  </a>
  <div class="stat-card">
    <div class="stat-icon green"><i class="fas fa-user-injured"></i></div>
    <div class="stat-body">
      <div class="stat-value">@patientCount</div>
      <div class="stat-label">Registered Patients</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon orange"><i class="fas fa-bed"></i></div>
    <div class="stat-body">
      <div class="stat-value">@roomCount</div>
      <div class="stat-label">Total Rooms</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon teal"><i class="fas fa-heartbeat"></i></div>
    <div class="stat-body">
      <div class="stat-value">24/7</div>
      <div class="stat-label">Patient Care</div>
    </div>
  </div>
</div>

<div class="dashboard-two-col">
  <div class="card">
    <div class="card-header">
      <span class="card-header-title"><i class="fas fa-tasks" style="color:var(--primary);margin-right:.5rem;"></i>My Tasks</span>
    </div>
    <div class="card-body nav-list">
      <a class="nav-list-item" asp-area="Nurse" asp-controller="Appointments" asp-action="Index">
        <i class="fas fa-calendar-alt"></i> Review Appointments
        <span class="badge badge-info ms-auto">@apptCount</span>
      </a>
      <a class="nav-list-item" asp-area="Nurse" asp-controller="Appointments" asp-action="Index">
        <i class="fas fa-user-check"></i> Check Patient Status
      </a>
      <a class="nav-list-item" asp-area="Nurse" asp-controller="Appointments" asp-action="Index">
        <i class="fas fa-edit"></i> Update Appointment Notes
      </a>
    </div>
  </div>
  <div class="card">
    <div class="card-header">
      <span class="card-header-title"><i class="fas fa-info-circle" style="color:var(--accent);margin-right:.5rem;"></i>Quick Reference</span>
    </div>
    <div class="card-body">
      <div class="overview-list">
        <div class="overview-item">
          <div class="ov-label"><i class="fas fa-calendar-check" style="color:var(--primary);"></i> Scheduled</div>
          <div class="ov-value"><span class="badge badge-info">Active</span></div>
        </div>
        <div class="overview-item">
          <div class="ov-label"><i class="fas fa-check-circle" style="color:var(--success);"></i> Completed</div>
          <div class="ov-value"><span class="badge badge-success">Done</span></div>
        </div>
        <div class="overview-item">
          <div class="ov-label"><i class="fas fa-times-circle" style="color:var(--danger);"></i> Cancelled</div>
          <div class="ov-value"><span class="badge badge-danger">N/A</span></div>
        </div>
        <div class="overview-item">
          <div class="ov-label"><i class="fas fa-redo" style="color:var(--warning);"></i> Rescheduled</div>
          <div class="ov-value"><span class="badge badge-warning">Pending</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
