@model PagedResult<AppointmentViewModel>
@{ ViewData["Title"] = "Appointments"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Appointments"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Nurse"; }
<div class="page-header"><div><div class="page-title">Appointments</div></div></div>
<div class="table-wrapper">
  <div class="table-toolbar">
    <div class="search-input-wrap"><i class="fas fa-search"></i><input type="text" class="search-input" id="s" placeholder="Search appointments…" oninput="filterTable('s','t')"/></div>
    <span class="text-muted" style="font-size:.8rem;">@Model.TotalCount appointment(s)</span>
  </div>
  @if (!Model.Items.Any()) { <div class="empty-state"><i class="fas fa-calendar-check"></i><h3>No appointments</h3></div> }
  else {
    <table id="t">
      <thead><tr><th>#</th><th>Number</th><th>Patient</th><th>Doctor</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber-1)*Model.PageSize+1; }
        @foreach (var a in Model.Items) {
          <tr><td>@(i++)</td><td><strong>@a.Number</strong></td><td>@a.PatientName</td><td>@a.DoctorName</td>
            <td>@a.AppointmentDate.ToString("MMM dd, hh:mm tt")</td>
            <td>@{ var nc = a.Status==Hospital.Models.Enums.AppointmentStatus.Completed?"badge-success":a.Status==Hospital.Models.Enums.AppointmentStatus.Cancelled?"badge-danger":a.Status==Hospital.Models.Enums.AppointmentStatus.InProgress?"badge-warning":"badge-info"; }<span class="badge @nc">@a.Status</span></td>
            <td><a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-warning btn-sm btn-icon"><i class="fas fa-pen"></i></a></td></tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
