@model AppointmentViewModel
@{ ViewData["Title"] = "Book Appointment"; ViewData["ShowSidebar"] = true; }
<div class="page-header"><div><div class="page-title">Book Appointment</div></div>
  <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div>
<div class="form-card">
  <div class="form-card-header"><h2><i class="fas fa-calendar-plus"></i> Book Appointment</h2></div>
  <div class="form-card-body">
    <form asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="PatientId"/><input type="hidden" asp-for="Number"/>
      <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid?"none":"flex")"></div>
      <div class="form-group"><label class="form-label" asp-for="DoctorId">Select Doctor *</label><select asp-for="DoctorId" class="form-control" asp-items="ViewBag.Doctors"><option value="">-- Choose Doctor --</option></select></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="Type">Type *</label>
          <select asp-for="Type" class="form-control"><option value="Consultation">Consultation</option><option value="Follow-up">Follow-up</option><option value="Emergency">Emergency</option></select></div>
        <div class="form-group"><label class="form-label" asp-for="AppointmentDate">Date & Time *</label><input asp-for="AppointmentDate" type="datetime-local" class="form-control"/></div>
      </div>
      <div class="form-group"><label class="form-label" asp-for="Description">Reason / Description</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><i class="fas fa-check"></i> Book Appointment</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial"/> }
