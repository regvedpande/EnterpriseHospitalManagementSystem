@model PagedResult<AppointmentViewModel>
@{ ViewData["Title"] = "My Appointments"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Appointments"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Patient"; }
<div class="page-header">
  <div><div class="page-title">My Appointments</div></div>
  <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Book Appointment</a>
</div>
<div class="table-wrapper">
  @if (!Model.Items.Any()) { <div class="empty-state"><i class="fas fa-calendar-check"></i><h3>No appointments</h3>
    <a asp-action="Create" class="btn btn-primary mt-2"><i class="fas fa-plus"></i> Book Now</a></div> }
  else {
    <table id="t">
      <thead><tr><th>#</th><th>Number</th><th>Doctor</th><th>Date</th><th>Type</th><th>Status</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber-1)*Model.PageSize+1; }
        @foreach (var a in Model.Items) {
          <tr><td>@(i++)</td><td><strong>@a.Number</strong></td><td>@a.DoctorName</td>
            <td>@a.AppointmentDate.ToString("MMM dd, yyyy hh:mm tt")</td><td>@a.Type</td>
            <td>@{ var sc = a.Status==Hospital.Models.Enums.AppointmentStatus.Completed?"badge-success":a.Status==Hospital.Models.Enums.AppointmentStatus.Cancelled?"badge-danger":a.Status==Hospital.Models.Enums.AppointmentStatus.InProgress?"badge-warning":"badge-info"; }<span class="badge @sc">@a.Status</span></td></tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
