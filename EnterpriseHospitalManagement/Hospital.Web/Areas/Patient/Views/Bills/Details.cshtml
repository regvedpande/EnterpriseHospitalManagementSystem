@model BillViewModel
@{ ViewData["Title"] = "Bill Details"; ViewData["ShowSidebar"] = true; }
<div class="page-header"><div><div class="page-title">Bill #@Model.BillNumber</div></div>
  <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div>
<div class="form-card">
  <div class="form-card-header"><h2><i class="fas fa-file-invoice-dollar"></i> Bill Details</h2></div>
  <div class="form-card-body">
    <table>
      <tr><td><strong>Doctor Charge</strong></td><td>@Model.DoctorCharge.ToString("C")</td></tr>
      <tr><td><strong>Medicine Charge</strong></td><td>@Model.MedicineCharge.ToString("C")</td></tr>
      <tr><td><strong>Room Charge</strong></td><td>@Model.RoomCharge.ToString("C")</td></tr>
      <tr><td><strong>Operation Charge</strong></td><td>@Model.OperationCharge.ToString("C")</td></tr>
      <tr><td><strong>Nursing Charge</strong></td><td>@Model.NursingCharge.ToString("C")</td></tr>
      <tr><td><strong>Lab Charge</strong></td><td>@Model.LabCharge.ToString("C")</td></tr>
      <tr><td><strong>Days</strong></td><td>@Model.NoOfDays</td></tr>
      <tr><td><strong>Advance Paid</strong></td><td>@Model.Advance.ToString("C")</td></tr>
      <tr style="font-size:1.2em;"><td><strong>Total</strong></td><td><strong>@Model.TotalBill.ToString("C")</strong></td></tr>
    </table>
    <p class="mt-3">@{ var bd = Model.Status==Hospital.Models.Enums.BillStatus.Paid?"badge-success":Model.Status==Hospital.Models.Enums.BillStatus.Overdue?"badge-danger":Model.Status==Hospital.Models.Enums.BillStatus.Cancelled?"badge-danger":Model.Status==Hospital.Models.Enums.BillStatus.PartiallyPaid?"badge-warning":"badge-info"; }<span class="badge @bd" style="font-size:1rem;">@Model.Status</span></p>
  </div>
</div>
