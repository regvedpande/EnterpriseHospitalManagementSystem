@model PagedResult<BillViewModel>
@{ ViewData["Title"] = "My Bills"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Bills"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Patient"; }
<div class="page-header"><div><div class="page-title">My Bills</div><small class="text-muted">View your billing history</small></div></div>
<div class="table-wrapper">
  <div class="table-toolbar">
    <div class="search-input-wrap"><i class="fas fa-search"></i><input type="text" class="search-input" id="s" placeholder="Search bills…" oninput="filterTable('s','t')"/></div>
    <span class="text-muted" style="font-size:.8rem;">@Model.TotalCount bill(s)</span>
  </div>
  @if (!Model.Items.Any()) { <div class="empty-state"><i class="fas fa-file-invoice-dollar"></i><h3>No bills</h3></div> }
  else {
    <table id="t">
      <thead><tr><th>#</th><th>Bill #</th><th>Total</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber-1)*Model.PageSize+1; }
        @foreach (var b in Model.Items) {
          <tr><td>@(i++)</td><td><strong>@b.BillNumber</strong></td><td>@b.TotalBill.ToString("C")</td>
            <td>@{ var bx = b.Status==Hospital.Models.Enums.BillStatus.Paid?"badge-success":b.Status==Hospital.Models.Enums.BillStatus.Overdue?"badge-danger":b.Status==Hospital.Models.Enums.BillStatus.Cancelled?"badge-danger":b.Status==Hospital.Models.Enums.BillStatus.PartiallyPaid?"badge-warning":"badge-info"; }<span class="badge @bx">@b.Status</span></td>
            <td>@b.CreatedDate.ToString("MMM dd, yyyy")</td>
            <td><a asp-action="Details" asp-route-id="@b.Id" class="btn btn-info btn-sm btn-icon"><i class="fas fa-eye"></i></a></td></tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
