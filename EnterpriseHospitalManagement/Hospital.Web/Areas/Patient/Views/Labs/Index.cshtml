@model PagedResult<LabViewModel>
@{ ViewData["Title"] = "My Lab Tests"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Labs"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Patient"; }
<div class="page-header"><div><div class="page-title">My Lab Tests</div></div></div>
<div class="table-wrapper">
  @if (!Model.Items.Any()) { <div class="empty-state"><i class="fas fa-flask"></i><h3>No lab tests</h3></div> }
  else {
    <table id="t">
      <thead><tr><th>#</th><th>Lab #</th><th>Test</th><th>Status</th><th>Result</th><th>Date</th></tr></thead>
      <tbody>
        @{ int i = (Model.PageNumber-1)*Model.PageSize+1; }
        @foreach (var l in Model.Items) {
          <tr><td>@(i++)</td><td><strong>@l.LabNumber</strong></td><td>@l.TestType</td>
            <td>@{ var lc = l.Status==Hospital.Models.Enums.LabTestStatus.Completed?"badge-success":l.Status==Hospital.Models.Enums.LabTestStatus.Cancelled?"badge-danger":l.Status==Hospital.Models.Enums.LabTestStatus.InProgress?"badge-warning":"badge-info"; }<span class="badge @lc">@l.Status</span></td>
            <td>@(l.TestResult ?? "Pending")</td><td>@l.CreatedDate.ToString("MMM dd, yyyy")</td></tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
