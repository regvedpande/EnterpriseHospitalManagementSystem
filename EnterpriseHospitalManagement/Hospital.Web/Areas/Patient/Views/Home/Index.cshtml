@{
    ViewData["Title"]       = "Patient Dashboard";
    ViewData["ShowSidebar"] = true;
    int hospitalCount = (int)(ViewBag.HospitalCount ?? 0);
    int doctorCount   = (int)(ViewBag.DoctorCount   ?? 0);
    int roomCount     = (int)(ViewBag.RoomCount     ?? 0);
    var doctors       = ViewBag.Doctors   as IEnumerable<Hospital.ViewModels.DoctorViewModel>       ?? Enumerable.Empty<Hospital.ViewModels.DoctorViewModel>();
    var hospitals     = ViewBag.Hospitals as IEnumerable<Hospital.ViewModels.HospitalInfoViewModel>  ?? Enumerable.Empty<Hospital.ViewModels.HospitalInfoViewModel>();
    string name = User.Identity?.Name?.Split('@')[0] ?? "Patient";
}

<div class="welcome-banner">
  <div>
    <h2>Welcome back, @name!</h2>
    <p>Your personal health portal — view appointments, test results, and medical reports.</p>
  </div>
  <div class="welcome-actions">
    <a asp-area="Patient" asp-controller="Appointments" asp-action="Create" class="btn btn-white-solid">
      <i class="fas fa-calendar-plus"></i> Book Appointment
    </a>
    <a asp-area="Patient" asp-controller="Appointments" asp-action="Index" class="btn btn-white">
      <i class="fas fa-list"></i> My Appointments
    </a>
  </div>
</div>

<!-- Quick Nav -->
<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:1.75rem;">
  <a class="stat-card stat-link" asp-area="Patient" asp-controller="Appointments" asp-action="Index">
    <div class="stat-icon blue"><i class="fas fa-calendar-check"></i></div>
    <div class="stat-body">
      <div class="stat-label" style="font-size:.875rem;font-weight:600;color:var(--text);">Appointments</div>
      <div class="stat-label">View & Book</div>
    </div>
    <i class="fas fa-chevron-right stat-arrow"></i>
  </a>
  <a class="stat-card stat-link" asp-area="Patient" asp-controller="Bills" asp-action="Index">
    <div class="stat-icon green"><i class="fas fa-file-invoice-dollar"></i></div>
    <div class="stat-body">
      <div class="stat-label" style="font-size:.875rem;font-weight:600;color:var(--text);">Bills</div>
      <div class="stat-label">View Statements</div>
    </div>
    <i class="fas fa-chevron-right stat-arrow"></i>
  </a>
  <a class="stat-card stat-link" asp-area="Patient" asp-controller="Labs" asp-action="Index">
    <div class="stat-icon orange"><i class="fas fa-flask"></i></div>
    <div class="stat-body">
      <div class="stat-label" style="font-size:.875rem;font-weight:600;color:var(--text);">Lab Results</div>
      <div class="stat-label">Test Reports</div>
    </div>
    <i class="fas fa-chevron-right stat-arrow"></i>
  </a>
  <a class="stat-card stat-link" asp-area="Patient" asp-controller="Reports" asp-action="Index">
    <div class="stat-icon teal"><i class="fas fa-notes-medical"></i></div>
    <div class="stat-body">
      <div class="stat-label" style="font-size:.875rem;font-weight:600;color:var(--text);">Medical Reports</div>
      <div class="stat-label">Doctor Notes</div>
    </div>
    <i class="fas fa-chevron-right stat-arrow"></i>
  </a>
</div>

<!-- Stats -->
<div class="stats-grid" style="margin-bottom:1.75rem;">
  <div class="stat-card">
    <div class="stat-icon blue"><i class="fas fa-hospital"></i></div>
    <div class="stat-body">
      <div class="stat-value">@hospitalCount</div>
      <div class="stat-label">Hospital Branches</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green"><i class="fas fa-user-md"></i></div>
    <div class="stat-body">
      <div class="stat-value">@doctorCount</div>
      <div class="stat-label">Available Doctors</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon orange"><i class="fas fa-bed"></i></div>
    <div class="stat-body">
      <div class="stat-value">@roomCount</div>
      <div class="stat-label">Total Rooms</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon teal"><i class="fas fa-heartbeat"></i></div>
    <div class="stat-body">
      <div class="stat-value">24/7</div>
      <div class="stat-label">Emergency Care</div>
    </div>
  </div>
</div>

<div class="dashboard-two-col">
  <!-- Available Doctors -->
  <div class="card">
    <div class="card-header">
      <span class="card-header-title"><i class="fas fa-user-md" style="color:var(--success);margin-right:.5rem;"></i>Available Doctors</span>
      <a asp-area="Patient" asp-controller="Appointments" asp-action="Create" class="btn btn-primary btn-sm">
        <i class="fas fa-calendar-plus"></i> Book
      </a>
    </div>
    @if (doctors.Any())
    {
      <div class="card-body" style="padding:.75rem;">
        <div class="doctor-grid">
          @foreach (var d in doctors)
          {
            <div class="doctor-card">
              <div class="doctor-avatar"><i class="fas fa-stethoscope"></i></div>
              <div class="doctor-info">
                <h4>@d.DoctorName</h4>
                <p>@d.Specialty</p>
                @if (!string.IsNullOrEmpty(d.Day))
                {
                  <p style="color:var(--primary);font-size:.78rem;font-weight:500;">
                    <i class="fas fa-clock" style="margin-right:.25rem;"></i>@d.Day  @d.StartTime–@d.EndTime
                  </p>
                }
              </div>
            </div>
          }
        </div>
      </div>
    }
    else
    {
      <div class="empty-state" style="padding:2rem;">
        <i class="fas fa-user-md"></i>
        <h3>No doctors listed</h3>
        <p>Doctor schedules will appear here once published.</p>
      </div>
    }
  </div>

  <!-- Hospital Branches -->
  <div class="card">
    <div class="card-header">
      <span class="card-header-title"><i class="fas fa-hospital" style="color:var(--primary);margin-right:.5rem;"></i>Hospital Branches</span>
    </div>
    @if (hospitals.Any())
    {
      <div class="card-body nav-list">
        @foreach (var h in hospitals)
        {
          <div class="activity-item">
            <div class="activity-icon" style="background:#dbeafe;color:#1d4ed8;">
              <i class="fas fa-hospital"></i>
            </div>
            <div class="activity-body">
              <strong>@h.Name</strong>
              @if (!string.IsNullOrEmpty(h.Address))
              {
                <span><i class="fas fa-map-marker-alt" style="margin-right:.25rem;"></i>@h.Address</span>
              }
            </div>
            @if (!string.IsNullOrEmpty(h.PhoneNumber))
            {
              <span class="activity-time"><i class="fas fa-phone" style="margin-right:.25rem;"></i>@h.PhoneNumber</span>
            }
          </div>
        }
      </div>
    }
    else
    {
      <div class="empty-state" style="padding:2rem;">
        <i class="fas fa-hospital"></i>
        <h3>No hospitals available</h3>
      </div>
    }
  </div>
</div>
