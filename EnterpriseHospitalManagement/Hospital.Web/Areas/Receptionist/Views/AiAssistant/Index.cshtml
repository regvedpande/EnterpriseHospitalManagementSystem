@{
    ViewData["Title"]       = "Reception AI Assistant";
    ViewData["ShowSidebar"] = true;
    bool cfg = (bool)(ViewBag.IsConfigured ?? false);
}
<div class="page-header">
  <div>
    <div class="page-title"><i class="fas fa-robot" style="color:#ea580c;"></i> Reception AI Assistant</div>
    <small class="text-muted">Patient triage · Department routing · Appointment urgency assessment</small>
  </div>
</div>
@if (!cfg) { <div class="alert alert-warning"><i class="fas fa-exclamation-triangle"></i> AI service not configured.</div> }
else {
<ul class="nav nav-pills mb-3 gap-2 flex-wrap" id="aiTabs">
  <li class="nav-item"><button class="nav-link active" data-tab="triage"><i class="fas fa-ambulance"></i> Symptom Triage</button></li>
  <li class="nav-item"><button class="nav-link" data-tab="chat"><i class="fas fa-comments"></i> Reception Chat</button></li>
</ul>

<div class="ai-tab" id="tab-triage">
  <div class="row g-3">
    <div class="col-lg-6">
      <div class="card h-100"><div class="card-header ai-hdr" style="background:linear-gradient(135deg,#ea580c,#fb923c);">
        <i class="fas fa-ambulance"></i> Patient Symptom Triage
      </div><div class="card-body d-flex flex-column gap-3">
        <p class="text-muted small mb-0">Enter the symptoms reported by the patient at reception. The AI will assess urgency and recommend the appropriate department.</p>
        <textarea id="t-symptoms" class="form-control" rows="6" placeholder="Describe patient's reported symptoms…&#10;&#10;e.g. 55yo male, sudden onset severe chest pain, radiating to left arm, started 30 minutes ago. Patient is sweaty and pale. Denies trauma.&#10;&#10;OR&#10;&#10;Young woman, 8 months pregnant, severe headache and blurred vision since this morning, no prior symptoms."></textarea>
        <button class="btn btn-danger" id="t-btn" onclick="runTriage()">
          <i class="fas fa-search-plus"></i> Assess Urgency
        </button>
      </div></div>
    </div>
    <div class="col-lg-6">
      <div id="t-res" style="display:none;">
        <div class="card h-100"><div class="card-header ai-hdr" style="background:linear-gradient(135deg,#1d4ed8,#3b82f6);">
          <i class="fas fa-clipboard-check"></i> Triage Assessment
        </div><div class="card-body">
          <div id="t-res-body" class="ai-result" style="border-color:#1d4ed8;background:#eff6ff;"></div>
        </div></div>
      </div>
      <div id="t-placeholder" class="card h-100" style="background:var(--surface);border:2px dashed var(--border);">
        <div class="card-body d-flex flex-column align-items-center justify-content-center text-muted" style="min-height:240px;">
          <i class="fas fa-clipboard-list fa-3x mb-3 opacity-25"></i>
          <p class="mb-0 text-center small">Enter patient symptoms and click <strong>Assess Urgency</strong><br>to see the triage result here.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Urgency Legend -->
  <div class="card mt-3">
    <div class="card-header" style="padding:.65rem 1.25rem;font-weight:600;font-size:.82rem;">Quick Urgency Reference</div>
    <div class="card-body d-flex flex-wrap gap-3" style="padding:.85rem 1.25rem;">
      <span class="badge" style="background:#dc2626;font-size:.78rem;padding:.4rem .8rem;"><i class="fas fa-exclamation"></i> Emergency — Immediate assessment, escalate at once</span>
      <span class="badge" style="background:#ea580c;font-size:.78rem;padding:.4rem .8rem;"><i class="fas fa-clock"></i> Urgent — Seen within 30 minutes</span>
      <span class="badge" style="background:#16a34a;font-size:.78rem;padding:.4rem .8rem;"><i class="fas fa-calendar-check"></i> Routine — Standard appointment</span>
    </div>
  </div>
</div>

<div class="ai-tab" id="tab-chat" style="display:none;">
  <div class="card" style="height:520px;display:flex;flex-direction:column;">
    <div class="card-header ai-hdr" style="background:linear-gradient(135deg,#ea580c,#1d4ed8);">
      <i class="fas fa-comments"></i> Reception Q&amp;A Chat
    </div>
    <div id="chatBox" class="flex-grow-1 p-3" style="overflow-y:auto;background:#f8f9fa;"></div>
    <div class="card-footer p-2"><div class="input-group">
      <input id="chatIn" type="text" class="form-control" placeholder="Ask about patient routing, procedures, or general hospital info…" onkeydown="if(event.key==='Enter')sendChat()"/>
      <button class="btn btn-primary" onclick="sendChat()"><i class="fas fa-paper-plane"></i></button>
    </div></div>
  </div>
</div>
}
<style>
.ai-hdr { color:#fff; font-weight:600; font-size:.875rem; padding:.75rem 1.25rem; border-radius:var(--radius) var(--radius) 0 0; }
.ai-result { background:#eff6ff; border-left:4px solid #ea580c; padding:.9rem 1.1rem; border-radius:6px; font-size:.875rem; line-height:1.65; }
.nav-pills .nav-link { background:#f1f3f5; color:var(--text); border:none; border-radius:8px; font-size:.8rem; padding:.4rem .9rem; }
.nav-pills .nav-link.active { background:#ea580c; color:#fff; }
.chat-msg { margin-bottom:.75rem; } .chat-msg.user .bubble { background:#ea580c; color:#fff; border-radius:18px 18px 4px 18px; margin-left:auto; max-width:80%; }
.chat-msg.ai .bubble { background:#fff; border:1px solid #dee2e6; border-radius:18px 18px 18px 4px; max-width:88%; }
.bubble { padding:.55rem .9rem; display:inline-block; font-size:.875rem; line-height:1.5; white-space:pre-wrap; word-break:break-word; }
.chat-msg.user { text-align:right; } .spinner-sm { width:1.1rem; height:1.1rem; }
</style>
<script>
document.querySelectorAll('#aiTabs .nav-link').forEach(btn=>{btn.addEventListener('click',()=>{document.querySelectorAll('#aiTabs .nav-link').forEach(b=>b.classList.remove('active'));document.querySelectorAll('.ai-tab').forEach(t=>t.style.display='none');btn.classList.add('active');document.getElementById('tab-'+btn.dataset.tab).style.display='';});});
async function runTriage(){
  const symp=document.getElementById('t-symptoms').value.trim();if(!symp){alert('Please enter patient symptoms.');return;}
  const btn=document.getElementById('t-btn');const resBody=document.getElementById('t-res-body');const resDiv=document.getElementById('t-res');const ph=document.getElementById('t-placeholder');
  const orig=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-sm"></span> Assessing…';
  const fd=new FormData();fd.append('symptoms',symp);fd.append('__RequestVerificationToken',getToken());
  try{const r=await fetch('@Url.Action("Triage","AiAssistant",new{area="Receptionist"})',{method:'POST',body:fd});const d=await r.json();resBody.innerHTML=renderMd(d.result||'No response.');resDiv.style.display='';ph.style.display='none';}
  catch(e){resBody.innerHTML='Error.';resDiv.style.display='';ph.style.display='none';}
  finally{btn.disabled=false;btn.innerHTML=orig;}
}
const chatHistory=[{role:'system',content:'You are MedCoreAI, a patient intake and triage assistant for hospital receptionists. Help with symptom assessment, patient routing, and reception procedures.'}];
async function sendChat(){const input=document.getElementById('chatIn');const msg=input.value.trim();if(!msg)return;appendBubble('user',escHtml(msg));chatHistory.push({role:'user',content:msg});input.value='';const t=appendBubble('ai','<span class="spinner-border spinner-sm"></span> Thinking…');try{const r=await fetch('@Url.Action("Chat","AiAssistant",new{area="Receptionist"})',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':getToken()},body:JSON.stringify({messages:chatHistory})});const d=await r.json();t.querySelector('.bubble').innerHTML=renderMd(d.result||'');chatHistory.push({role:'assistant',content:d.result||''});}catch(e){t.querySelector('.bubble').textContent='Error.';}scrollChat();}
function appendBubble(r,h){const b=document.getElementById('chatBox');const d=document.createElement('div');d.className=`chat-msg ${r}`;d.innerHTML=`<div class="bubble">${h}</div>`;b.appendChild(d);scrollChat();return d;}
function scrollChat(){const b=document.getElementById('chatBox');b.scrollTop=b.scrollHeight;}
function getToken(){return document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';}
function escHtml(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function renderMd(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/^### (.+)$/gm,'<strong style="font-size:.93em;text-decoration:underline">$1</strong>').replace(/^## (.+)$/gm,'<strong style="font-size:.97em">$1</strong>').replace(/^# (.+)$/gm,'<strong style="font-size:1.02em">$1</strong>').replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>').replace(/^- (.+)$/gm,'• $1').replace(/\n/g,'<br>');}
document.addEventListener('DOMContentLoaded',()=>{const f=document.createElement('form');f.innerHTML='@Html.AntiForgeryToken()';document.body.appendChild(f);});
</script>
