@{
    ViewData["Title"]       = "Receptionist Dashboard";
    ViewData["ShowSidebar"] = true;
    int apptCount    = (int)(ViewBag.AppointmentCount ?? 0);
    int patientCount = (int)(ViewBag.PatientCount     ?? 0);
    int doctorCount  = (int)(ViewBag.DoctorCount      ?? 0);
    string name = User.Identity?.Name ?? "Receptionist";
}

<div class="welcome-banner">
  <div>
    <h2>Welcome, @name</h2>
    <p>Reception Desk — Schedule appointments and coordinate patient flow.</p>
  </div>
  <div class="welcome-actions">
    <a asp-area="Receptionist" asp-controller="Appointments" asp-action="Create" class="btn btn-white-solid">
      <i class="fas fa-calendar-plus"></i> Schedule Appointment
    </a>
    <a asp-area="Receptionist" asp-controller="Appointments" asp-action="Index" class="btn btn-white">
      <i class="fas fa-list"></i> All Appointments
    </a>
  </div>
</div>

<div class="stats-grid">
  <a class="stat-card stat-link" asp-area="Receptionist" asp-controller="Appointments" asp-action="Index">
    <div class="stat-icon blue"><i class="fas fa-calendar-check"></i></div>
    <div class="stat-body">
      <div class="stat-value">@apptCount</div>
      <div class="stat-label">Total Appointments</div>
    </div>
    <i class="fas fa-chevron-right stat-arrow"></i>
  </a>
  <div class="stat-card">
    <div class="stat-icon green"><i class="fas fa-user-injured"></i></div>
    <div class="stat-body">
      <div class="stat-value">@patientCount</div>
      <div class="stat-label">Registered Patients</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon orange"><i class="fas fa-user-md"></i></div>
    <div class="stat-body">
      <div class="stat-value">@doctorCount</div>
      <div class="stat-label">Available Doctors</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon teal"><i class="fas fa-concierge-bell"></i></div>
    <div class="stat-body">
      <div class="stat-value">Active</div>
      <div class="stat-label">Reception Status</div>
    </div>
  </div>
</div>

<div class="dashboard-two-col">
  <div class="card">
    <div class="card-header">
      <span class="card-header-title"><i class="fas fa-bolt" style="color:var(--warning);margin-right:.5rem;"></i>Quick Actions</span>
    </div>
    <div class="card-body nav-list">
      <a class="nav-list-item" asp-area="Receptionist" asp-controller="Appointments" asp-action="Create">
        <i class="fas fa-calendar-plus"></i> Schedule New Appointment
      </a>
      <a class="nav-list-item" asp-area="Receptionist" asp-controller="Appointments" asp-action="Index">
        <i class="fas fa-list-alt"></i> Manage Appointments
        <span class="badge badge-info ms-auto">@apptCount</span>
      </a>
    </div>
  </div>
  <div class="card">
    <div class="card-header">
      <span class="card-header-title"><i class="fas fa-chart-bar" style="color:var(--primary);margin-right:.5rem;"></i>Today's Overview</span>
    </div>
    <div class="card-body">
      <div class="overview-list">
        <div class="overview-item">
          <div class="ov-label"><i class="fas fa-calendar-check" style="color:var(--primary);"></i> All Appointments</div>
          <div class="ov-value"><span class="badge badge-info">@apptCount</span></div>
        </div>
        <div class="overview-item">
          <div class="ov-label"><i class="fas fa-user-md" style="color:var(--success);"></i> Active Doctors</div>
          <div class="ov-value"><span class="badge badge-success">@doctorCount</span></div>
        </div>
        <div class="overview-item">
          <div class="ov-label"><i class="fas fa-users" style="color:var(--accent);"></i> Total Patients</div>
          <div class="ov-value"><span class="badge badge-secondary">@patientCount</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
