@model AppointmentViewModel
@{ ViewData["Title"] = "Edit Appointment"; ViewData["ShowSidebar"] = true; }
<div class="page-header"><div><div class="page-title">Edit Appointment</div></div>
  <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div>
<div class="form-card">
  <div class="form-card-body">
    <form asp-action="Edit" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id"/><input type="hidden" asp-for="Number"/>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="DoctorId">Doctor *</label><select asp-for="DoctorId" class="form-control" asp-items="ViewBag.Doctors"></select></div>
        <div class="form-group"><label class="form-label" asp-for="PatientId">Patient *</label><select asp-for="PatientId" class="form-control" asp-items="ViewBag.Patients"></select></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label" asp-for="AppointmentDate">Date & Time</label><input asp-for="AppointmentDate" type="datetime-local" class="form-control"/></div>
        <div class="form-group"><label class="form-label" asp-for="Status">Status</label><select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<Hospital.Models.Enums.AppointmentStatus>()"></select></div>
      </div>
      <div class="form-actions"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save</button><a asp-action="Index" class="btn btn-secondary">Cancel</a></div>
    </form>
  </div>
</div>
