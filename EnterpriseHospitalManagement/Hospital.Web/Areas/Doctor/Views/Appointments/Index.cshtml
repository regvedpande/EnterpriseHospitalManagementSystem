@model PagedResult<AppointmentViewModel>
@{ ViewData["Title"] = "My Appointments"; ViewData["ShowSidebar"] = true;
   ViewData["Page"] = Model.PageNumber; ViewData["TotalPages"] = Model.TotalPages;
   ViewData["Size"] = Model.PageSize; ViewData["TotalCount"] = Model.TotalCount;
   ViewData["PagCtrl"] = "Appointments"; ViewData["PagAction"] = "Index"; ViewData["PagArea"] = "Doctor"; }
<div class="page-header">
  <div><div class="page-title">My Appointments</div><small class="text-muted">Your scheduled appointments</small></div>
  <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> New Appointment</a>
</div>
<div class="table-wrapper">
  <div class="table-toolbar">
    <div class="search-input-wrap"><i class="fas fa-search"></i>
      <input type="text" class="search-input" placeholder="Search patient, type…" oninput="filterTable('s','t')" id="s"/>
    </div>
    <span class="text-muted" style="font-size:.8rem;">@Model.TotalCount total</span>
  </div>
  @if (!Model.Items.Any())
  {
    <div class="empty-state">
      <i class="fas fa-calendar-check"></i>
      <h3>No appointments yet</h3>
      <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Create First</a>
    </div>
  }
  else
  {
    <table id="t">
      <thead>
        <tr><th>#</th><th>Number</th><th>Patient</th><th>Date</th><th>Type</th><th>Status</th><th>Actions</th></tr>
      </thead>
      <tbody>
        @{ int i = (Model.PageNumber-1)*Model.PageSize+1; }
        @foreach (var a in Model.Items)
        {
          <tr>
            <td>@(i++)</td>
            <td><strong>@a.Number</strong></td>
            <td>@a.PatientName</td>
            <td>@a.AppointmentDate.ToString("MMM dd, yyyy hh:mm tt")</td>
            <td>@a.Type</td>
            <td>
              @{
                var sc = a.Status == Hospital.Models.Enums.AppointmentStatus.Completed ? "badge-success"
                       : a.Status == Hospital.Models.Enums.AppointmentStatus.Cancelled  ? "badge-danger"
                       : a.Status == Hospital.Models.Enums.AppointmentStatus.InProgress ? "badge-warning"
                       : "badge-info";
              }
              <span class="badge @sc">@a.Status</span>
            </td>
            <td>
              <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-warning btn-sm btn-icon"><i class="fas fa-pen"></i></a>
            </td>
          </tr>
        }
      </tbody>
    </table>
    <partial name="_Pagination"/>
  }
</div>
