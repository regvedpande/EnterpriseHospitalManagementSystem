<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] — HMS</title>
  <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
  @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ── TOP NAV ─────────────────────────────────────────────────────────── -->
<nav class="topbar">
  <a class="topbar-brand" asp-controller="Home" asp-action="Index" asp-area="">
    <i class="fas fa-hospital-alt"></i> HMS
  </a>
  <div class="topbar-spacer"></div>
  <div class="topbar-nav">
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
      <div class="user-dropdown" id="userDropdown">
        <button class="user-btn" onclick="toggleDropdown()">
          <span class="avatar">@(User.Identity.Name?.Substring(0,1).ToUpper() ?? "U")</span>
          <span>@User.Identity.Name</span>
          <i class="fas fa-chevron-down" style="font-size:.7rem; opacity:.7;"></i>
        </button>
        <div class="dropdown-menu-custom" id="dropdownMenu">
          @if (User.IsInRole("Website_Admin"))
          { <a asp-area="Admin" asp-controller="Hospitals" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a> }
          @if (User.IsInRole("Website_Doctor"))
          { <a asp-area="Doctor" asp-controller="Doctors" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a> }
          @if (User.IsInRole("Website_Patient"))
          { <a asp-area="Patient" asp-controller="Home" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a> }
          @if (User.IsInRole("Website_Nurse"))
          { <a asp-area="Nurse" asp-controller="Home" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a> }
          @if (User.IsInRole("Website_Pharmacist"))
          { <a asp-area="Pharmacist" asp-controller="Home" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a> }
          @if (User.IsInRole("Website_LabTech"))
          { <a asp-area="LabTech" asp-controller="Home" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a> }
          @if (User.IsInRole("Website_Receptionist"))
          { <a asp-area="Receptionist" asp-controller="Home" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a> }
          @if (User.IsInRole("Website_Accountant"))
          { <a asp-area="Accountant" asp-controller="Home" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a> }
          <div class="divider"></div>
          <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post" id="logoutForm">
            @Html.AntiForgeryToken()
            <button type="submit" class="danger"><i class="fas fa-sign-out-alt"></i> Logout</button>
          </form>
        </div>
      </div>
    }
    else
    {
      <a class="nav-link" asp-controller="Auth" asp-action="Login" asp-area="">
        <i class="fas fa-sign-in-alt"></i><span> Login</span>
      </a>
      <a class="nav-link" asp-controller="Auth" asp-action="Register" asp-area="">
        <i class="fas fa-user-plus"></i><span> Register</span>
      </a>
    }
  </div>
</nav>

<!-- ── BODY ────────────────────────────────────────────────────────────── -->
@{
  var hasSidebar = ViewData["ShowSidebar"] as bool? ?? false;
  var area       = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
}
<div class="page-wrapper @(hasSidebar ? "with-sidebar" : "")">
  @if (hasSidebar)
  {
    <aside class="sidebar">
      @{ var ctrl = ViewContext.RouteData.Values["controller"]?.ToString(); }
      @if (area == "Admin")
      {
        <div class="sidebar-section">
          <div class="sidebar-label">ADMIN</div>
          <a class="sidebar-link @(ctrl=="Hospitals"?"active":"")" asp-area="Admin" asp-controller="Hospitals" asp-action="Index"><i class="fas fa-hospital"></i> Hospitals</a>
          <a class="sidebar-link @(ctrl=="Rooms"?"active":"")" asp-area="Admin" asp-controller="Rooms" asp-action="Index"><i class="fas fa-door-open"></i> Rooms</a>
          <a class="sidebar-link @(ctrl=="Departments"?"active":"")" asp-area="Admin" asp-controller="Departments" asp-action="Index"><i class="fas fa-sitemap"></i> Departments</a>
          <a class="sidebar-link @(ctrl=="Users"?"active":"")" asp-area="Admin" asp-controller="Users" asp-action="Index"><i class="fas fa-users"></i> Users</a>
          <a class="sidebar-link @(ctrl=="Contacts"?"active":"")" asp-area="Admin" asp-controller="Contacts" asp-action="Index"><i class="fas fa-address-book"></i> Contacts</a>
        </div>
        <div class="sidebar-section">
          <div class="sidebar-label">CLINICAL</div>
          <a class="sidebar-link @(ctrl=="Appointments"?"active":"")" asp-area="Admin" asp-controller="Appointments" asp-action="Index"><i class="fas fa-calendar-check"></i> Appointments</a>
          <a class="sidebar-link @(ctrl=="PatientReports"?"active":"")" asp-area="Admin" asp-controller="PatientReports" asp-action="Index"><i class="fas fa-file-medical"></i> Reports</a>
          <a class="sidebar-link @(ctrl=="Labs"?"active":"")" asp-area="Admin" asp-controller="Labs" asp-action="Index"><i class="fas fa-flask"></i> Lab Tests</a>
        </div>
        <div class="sidebar-section">
          <div class="sidebar-label">PHARMACY</div>
          <a class="sidebar-link @(ctrl=="Medicines"?"active":"")" asp-area="Admin" asp-controller="Medicines" asp-action="Index"><i class="fas fa-pills"></i> Medicines</a>
          <a class="sidebar-link @(ctrl=="Suppliers"?"active":"")" asp-area="Admin" asp-controller="Suppliers" asp-action="Index"><i class="fas fa-truck"></i> Suppliers</a>
        </div>
        <div class="sidebar-section">
          <div class="sidebar-label">FINANCE</div>
          <a class="sidebar-link @(ctrl=="Bills"?"active":"")" asp-area="Admin" asp-controller="Bills" asp-action="Index"><i class="fas fa-file-invoice-dollar"></i> Bills</a>
          <a class="sidebar-link @(ctrl=="Insurance"?"active":"")" asp-area="Admin" asp-controller="Insurance" asp-action="Index"><i class="fas fa-shield-alt"></i> Insurance</a>
          <a class="sidebar-link @(ctrl=="Payrolls"?"active":"")" asp-area="Admin" asp-controller="Payrolls" asp-action="Index"><i class="fas fa-money-check-alt"></i> Payroll</a>
        </div>
      }
      @if (area == "Doctor")
      {
        <div class="sidebar-section">
          <div class="sidebar-label">DOCTOR</div>
          <a class="sidebar-link @(ctrl=="Doctors"?"active":"")" asp-area="Doctor" asp-controller="Doctors" asp-action="Index"><i class="fas fa-calendar-alt"></i> My Timings</a>
          <a class="sidebar-link @(ctrl=="Appointments"?"active":"")" asp-area="Doctor" asp-controller="Appointments" asp-action="Index"><i class="fas fa-calendar-check"></i> Appointments</a>
          <a class="sidebar-link @(ctrl=="Patients"?"active":"")" asp-area="Doctor" asp-controller="Patients" asp-action="Index"><i class="fas fa-file-medical"></i> Patient Reports</a>
        </div>
      }
      @if (area == "Patient")
      {
        <div class="sidebar-section">
          <div class="sidebar-label">PATIENT</div>
          <a class="sidebar-link @(ctrl=="Home"?"active":"")" asp-area="Patient" asp-controller="Home" asp-action="Index"><i class="fas fa-th-large"></i> Dashboard</a>
          <a class="sidebar-link @(ctrl=="Appointments"?"active":"")" asp-area="Patient" asp-controller="Appointments" asp-action="Index"><i class="fas fa-calendar-check"></i> Appointments</a>
          <a class="sidebar-link @(ctrl=="Bills"?"active":"")" asp-area="Patient" asp-controller="Bills" asp-action="Index"><i class="fas fa-file-invoice-dollar"></i> My Bills</a>
          <a class="sidebar-link @(ctrl=="Labs"?"active":"")" asp-area="Patient" asp-controller="Labs" asp-action="Index"><i class="fas fa-flask"></i> Lab Results</a>
          <a class="sidebar-link @(ctrl=="Reports"?"active":"")" asp-area="Patient" asp-controller="Reports" asp-action="Index"><i class="fas fa-file-medical"></i> Reports</a>
        </div>
      }
      @if (area == "Nurse")
      {
        <div class="sidebar-section">
          <div class="sidebar-label">NURSE</div>
          <a class="sidebar-link @(ctrl=="Home"?"active":"")" asp-area="Nurse" asp-controller="Home" asp-action="Index"><i class="fas fa-th-large"></i> Dashboard</a>
          <a class="sidebar-link @(ctrl=="Appointments"?"active":"")" asp-area="Nurse" asp-controller="Appointments" asp-action="Index"><i class="fas fa-calendar-check"></i> Appointments</a>
        </div>
      }
      @if (area == "Pharmacist")
      {
        <div class="sidebar-section">
          <div class="sidebar-label">PHARMACIST</div>
          <a class="sidebar-link @(ctrl=="Home"?"active":"")" asp-area="Pharmacist" asp-controller="Home" asp-action="Index"><i class="fas fa-th-large"></i> Dashboard</a>
          <a class="sidebar-link @(ctrl=="Medicines"?"active":"")" asp-area="Pharmacist" asp-controller="Medicines" asp-action="Index"><i class="fas fa-pills"></i> Medicines</a>
          <a class="sidebar-link @(ctrl=="Prescriptions"?"active":"")" asp-area="Pharmacist" asp-controller="Prescriptions" asp-action="Index"><i class="fas fa-prescription"></i> Prescriptions</a>
        </div>
      }
      @if (area == "LabTech")
      {
        <div class="sidebar-section">
          <div class="sidebar-label">LAB TECH</div>
          <a class="sidebar-link @(ctrl=="Home"?"active":"")" asp-area="LabTech" asp-controller="Home" asp-action="Index"><i class="fas fa-th-large"></i> Dashboard</a>
          <a class="sidebar-link @(ctrl=="Labs"?"active":"")" asp-area="LabTech" asp-controller="Labs" asp-action="Index"><i class="fas fa-flask"></i> Lab Tests</a>
        </div>
      }
      @if (area == "Receptionist")
      {
        <div class="sidebar-section">
          <div class="sidebar-label">RECEPTIONIST</div>
          <a class="sidebar-link @(ctrl=="Home"?"active":"")" asp-area="Receptionist" asp-controller="Home" asp-action="Index"><i class="fas fa-th-large"></i> Dashboard</a>
          <a class="sidebar-link @(ctrl=="Appointments"?"active":"")" asp-area="Receptionist" asp-controller="Appointments" asp-action="Index"><i class="fas fa-calendar-check"></i> Appointments</a>
        </div>
      }
      @if (area == "Accountant")
      {
        <div class="sidebar-section">
          <div class="sidebar-label">ACCOUNTANT</div>
          <a class="sidebar-link @(ctrl=="Home"?"active":"")" asp-area="Accountant" asp-controller="Home" asp-action="Index"><i class="fas fa-th-large"></i> Dashboard</a>
          <a class="sidebar-link @(ctrl=="Bills"?"active":"")" asp-area="Accountant" asp-controller="Bills" asp-action="Index"><i class="fas fa-file-invoice-dollar"></i> Bills</a>
          <a class="sidebar-link @(ctrl=="Payrolls"?"active":"")" asp-area="Accountant" asp-controller="Payrolls" asp-action="Index"><i class="fas fa-money-check-alt"></i> Payroll</a>
        </div>
      }
    </aside>
  }

  <div class="main-content">
    @if (TempData["success"] != null)
    {
      <div class="alert alert-success">
        <i class="fas fa-check-circle"></i>
        <span>@TempData["success"]</span>
        <button class="alert-dismiss" onclick="this.parentElement.remove()">×</button>
      </div>
    }
    @if (TempData["error"] != null)
    {
      <div class="alert alert-danger">
        <i class="fas fa-exclamation-circle"></i>
        <span>@TempData["error"]</span>
        <button class="alert-dismiss" onclick="this.parentElement.remove()">×</button>
      </div>
    }
    @RenderBody()
  </div>
</div>

<!-- ── DELETE CONFIRM MODAL ─────────────────────────────────────────────── -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal-box">
    <div class="modal-icon">🗑️</div>
    <div class="modal-title">Confirm Delete</div>
    <div class="modal-text">Are you sure? This action cannot be undone.</div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeDeleteModal()">Cancel</button>
      <button class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
    </div>
  </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Dropdown toggle
  function toggleDropdown() {
    document.getElementById('dropdownMenu').classList.toggle('show');
  }
  document.addEventListener('click', function(e) {
    const d = document.getElementById('userDropdown');
    if (d && !d.contains(e.target)) document.getElementById('dropdownMenu')?.classList.remove('show');
  });

  // Delete modal
  let _deleteForm = null;
  function confirmDelete(formId) {
    _deleteForm = document.getElementById(formId);
    document.getElementById('deleteModal').classList.add('active');
  }
  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.remove('active');
    _deleteForm = null;
  }
  document.getElementById('confirmDeleteBtn')?.addEventListener('click', function() {
    if (_deleteForm) _deleteForm.submit();
  });
  document.getElementById('deleteModal')?.addEventListener('click', function(e) {
    if (e.target === this) closeDeleteModal();
  });

  // Auto-dismiss alerts after 4s
  setTimeout(() => {
    document.querySelectorAll('.alert').forEach(a => {
      a.style.transition = 'opacity .4s'; a.style.opacity = '0';
      setTimeout(() => a.remove(), 400);
    });
  }, 4000);

  // Table search
  function filterTable(inputId, tableId) {
    const q = document.getElementById(inputId).value.toLowerCase();
    document.querySelectorAll('#' + tableId + ' tbody tr').forEach(row => {
      row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
