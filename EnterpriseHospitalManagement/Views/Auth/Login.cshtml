@model Hospital.Web.Controllers.LoginVm
@{
    ViewData["Title"] = "Login";
    ViewData["ShowSidebar"] = false;
    Layout = "_Layout";
}

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card-header">
      <div class="logo"><i class="fas fa-hospital-alt"></i> HMS</div>
      <p>Sign in to your account</p>
    </div>
    <div class="auth-card-body">
      <form asp-action="Login" method="post">
        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]"/>
        <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "flex")"></div>

        <div class="form-group">
          <label class="form-label" asp-for="Email">Email address</label>
          <input asp-for="Email" class="form-control" placeholder="admin@hospital.com" autocomplete="email"/>
          <span asp-validation-for="Email" class="invalid-feedback"></span>
        </div>
        <div class="form-group">
          <label class="form-label" asp-for="Password">Password</label>
          <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password"/>
          <span asp-validation-for="Password" class="invalid-feedback"></span>
        </div>
        <div class="form-group" style="display:flex; align-items:center; gap:.5rem;">
          <input asp-for="RememberMe" type="checkbox" id="RememberMe" style="width:16px; height:16px;"/>
          <label for="RememberMe" style="margin:0; font-size:.875rem;">Remember me for 8 hours</label>
        </div>
        <button type="submit" class="btn btn-primary w-100 btn-lg" style="margin-top:.5rem;">
          <i class="fas fa-sign-in-alt"></i> Sign In
        </button>
      </form>
    </div>
    <div class="auth-card-footer">
      Don't have an account? <a asp-action="Register">Register here</a>
    </div>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial"/>
}
